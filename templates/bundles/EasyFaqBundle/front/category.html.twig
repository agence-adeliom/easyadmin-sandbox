{% extends '@!EasyFaq/front/category.html.twig' %}

{% block title %}{{ category.name }} - FAQ - Adeliom EasyAdmin Sandbox{% endblock %}

{% block easy_page_page_content %}
    <!-- Category Header -->
    <header class="bg-gradient-to-r from-emerald-600 to-teal-600 text-white">
        <div class="container mx-auto px-6 py-16">
            <div class="max-w-3xl">
                <!-- Breadcrumb -->
                <nav class="mb-6">
                    <ol class="flex items-center space-x-2 text-emerald-100">
                        <li><a href="{{ path('easy_faq_category_index') }}" class="hover:text-white transition-colors">FAQ</a></li>
                        <li>
                            <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                            </svg>
                        </li>
                        <li class="text-white font-medium">{{ category.name }}</li>
                    </ol>
                </nav>

                <h1 class="text-4xl font-bold mb-4">{{ category.name }}</h1>
                {% if category.seo and category.seo.description %}
                    <p class="text-xl text-emerald-100">{{ category.seo.description }}</p>
                {% endif %}

                <div class="mt-6 flex items-center space-x-6 text-emerald-200">
                    {% if entries is defined %}
                        <div class="flex items-center">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            {{ entries|length }} {{ entries|length == 1 ? 'question' : 'questions' }}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <div class="container mx-auto px-6 py-12">
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
            <!-- FAQ Content -->
            <main class="lg:col-span-3">
                {% if entries is defined and entries|length > 0 %}
                    <!-- Filter/Sort Bar -->
                    <div class="flex items-center justify-between mb-8 pb-4 border-b border-gray-200">
                        <p class="text-gray-600">
                            Showing {{ entries|length }} {{ entries|length == 1 ? 'question' : 'questions' }} in <strong>{{ category.name }}</strong>
                        </p>
                        <div class="flex items-center space-x-4">
                            <select class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-transparent outline-none">
                                <option>Most Recent</option>
                                <option>Alphabetical</option>
                                <option>Most Popular</option>
                            </select>
                        </div>
                    </div>

                    <!-- FAQ List -->
                    <div class="space-y-6">
                        {% for entry in entries %}
                            <div class="bg-white rounded-lg shadow-md border border-gray-200">
                                <button class="w-full px-6 py-5 text-left flex items-center justify-between hover:bg-gray-50 transition-colors focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-inset"
                                        onclick="toggleFaq('faq-{{ loop.index }}')">
                                    <div class="flex-1 pr-4">
                                        <h3 class="text-lg font-semibold text-gray-800 mb-2">{{ entry.name }}</h3>
                                        <div class="flex items-center text-sm text-gray-500">
                                            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                            </svg>
                                            <span>Updated recently</span>
                                        </div>
                                    </div>
                                    <div class="flex items-center space-x-3">
                                        <div class="flex items-center text-sm text-gray-500">
                                            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                                            </svg>
                                            <span>8</span>
                                        </div>
                                        <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                                        </svg>
                                    </div>
                                </button>

                                <div id="faq-{{ loop.index }}" class="hidden px-6 pb-6">
                                    <div class="pt-4 border-t border-gray-100">
                                        <div class="prose max-w-none text-gray-700">
                                            {{ entry.answer|raw }}
                                        </div>

                                        <!-- FAQ Actions -->
                                        <div class="mt-6 pt-4 border-t border-gray-100 flex items-center justify-between">
                                            <div class="flex items-center space-x-4 text-sm text-gray-500">
                                                <span>Was this helpful?</span>
                                                <button class="flex items-center hover:text-emerald-600 transition-colors">
                                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"></path>
                                                    </svg>
                                                    Yes
                                                </button>
                                                <button class="flex items-center hover:text-emerald-600 transition-colors">
                                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14H5.236a2 2 0 01-1.789-2.894l3.5-7A2 2 0 018.736 3h4.018c.163 0 .326.02.485.06L17 4m-7 10v2a2 2 0 002 2h.095c.5 0 .905-.405.905-.905 0-.714.211-1.412.608-2.006L17 13V4m-7 10h2m5-10h2a2 2 0 012 2v6a2 2 0 01-2 2h-2.5"></path>
                                                    </svg>
                                                    No
                                                </button>
                                            </div>

                                            <button class="text-sm text-emerald-600 hover:text-emerald-800 font-medium transition-colors">
                                                Share this answer
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    <!-- Pagination -->
                    <div class="mt-12 flex justify-center">
                        <div class="flex space-x-2">
                            <button class="px-4 py-2 text-emerald-600 border border-emerald-600 rounded-lg hover:bg-emerald-600 hover:text-white transition-colors">
                                Previous
                            </button>
                            <button class="px-4 py-2 bg-emerald-600 text-white rounded-lg">1</button>
                            <button class="px-4 py-2 text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-100 transition-colors">2</button>
                            <button class="px-4 py-2 text-emerald-600 border border-emerald-600 rounded-lg hover:bg-emerald-600 hover:text-white transition-colors">
                                Next
                            </button>
                        </div>
                    </div>
                {% else %}
                    <!-- Empty State -->
                    <div class="text-center py-16">
                        <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <h3 class="text-xl font-semibold text-gray-800 mb-2">No Questions in This Category</h3>
                        <p class="text-gray-600 mb-6">There are no questions in the {{ category.name }} category yet.</p>
                        <a href="{{ path('easy_faq_category_index') }}"
                           class="inline-flex items-center px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors">
                            Browse All FAQs
                        </a>
                    </div>
                {% endif %}
            </main>

            <!-- Sidebar -->
            <aside class="lg:col-span-1">
                <div class="space-y-6">
                    <!-- Back to FAQ -->
                    <div class="bg-white rounded-lg shadow-md p-6">
                        <a href="{{ path('easy_faq_category_index') }}"
                           class="inline-flex items-center text-emerald-600 hover:text-emerald-800 font-medium transition-colors">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                            </svg>
                            Back to All FAQs
                        </a>
                    </div>

                    <!-- Category Info -->
                    <div class="bg-white rounded-lg shadow-md p-6">
                        <h3 class="text-lg font-semibold text-gray-800 mb-4">About This Category</h3>
                        {% if category.seo and category.seo.description %}
                            <p class="text-gray-600 text-sm">{{ category.seo.description }}</p>
                        {% else %}
                            <p class="text-gray-600 text-sm">Find answers to questions related to {{ category.name }}.</p>
                        {% endif %}
                    </div>

                    <!-- Search in Category -->
                    <div class="bg-white rounded-lg shadow-md p-6">
                        <h3 class="text-lg font-semibold text-gray-800 mb-4">Search in Category</h3>
                        <div class="relative">
                            <input type="search" placeholder="Search in {{ category.name }}..."
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-transparent outline-none text-sm">
                            <div class="absolute inset-y-0 right-0 flex items-center pr-3">
                                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                </svg>
                            </div>
                        </div>
                    </div>

                    <!-- Related Categories -->
                    {% if categories is defined and categories|length > 1 %}
                        <div class="bg-white rounded-lg shadow-md p-6">
                            <h3 class="text-lg font-semibold text-gray-800 mb-4">Other Categories</h3>
                            <div class="space-y-2">
                                {% for cat in categories %}
                                    {% if cat.slug != category.slug %}
                                        <a href="{{ path('easy_faq_category_index', {"category" : cat.slug}) }}"
                                           class="block p-2 text-gray-700 hover:text-emerald-600 hover:bg-emerald-50 rounded transition-colors">
                                            {{ cat.name }}
                                        </a>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                    <!-- Contact Support -->
                    <div class="bg-emerald-50 rounded-lg p-6">
                        <div class="text-center">
                            <svg class="w-12 h-12 text-emerald-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M12 2.25a9.75 9.75 0 11-9.75 9.75A9.75 9.75 0 0112 2.25z"></path>
                            </svg>
                            <h4 class="text-lg font-semibold text-gray-800 mb-2">Still Need Help?</h4>
                            <p class="text-sm text-gray-600 mb-4">Contact our support team for personalized assistance.</p>
                            <a href="#" class="inline-flex items-center px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors text-sm font-medium">
                                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                </svg>
                                Contact Support
                            </a>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </div>

    <script>
        function toggleFaq(id) {
            const element = document.getElementById(id);
            const button = element.previousElementSibling;
            const arrow = button.querySelector('svg:last-child');

            if (element.classList.contains('hidden')) {
                element.classList.remove('hidden');
                arrow.style.transform = 'rotate(180deg)';
            } else {
                element.classList.add('hidden');
                arrow.style.transform = 'rotate(0deg)';
            }
        }
    </script>
{% endblock %}
