{% extends '@!EasyFaq/front/root.html.twig' %}

{% block title %}{{ page.name }} - Adeliom EasyAdmin Sandbox{% endblock %}

{% block easy_page_page_content %}
    <!-- FAQ Header -->
    <header class="bg-gradient-to-r from-emerald-600 to-teal-600 text-white">
        <div class="container mx-auto px-6 py-16">
            <div class="text-center">
                <h1 class="text-4xl font-bold mb-4">{{ page.name }}</h1>
                <p class="text-xl text-emerald-100">Find answers to commonly asked questions</p>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <div class="container mx-auto px-6 py-12">
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
            <!-- Categories Sidebar -->
            <aside class="lg:col-span-1">
                <div class="bg-white rounded-lg shadow-md p-6 sticky top-6">
                    <h3 class="text-xl font-bold text-gray-800 mb-6 flex items-center">
                        <svg class="w-5 h-5 mr-2 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                        </svg>
                        Categories
                    </h3>

                    {% if categories is defined and categories|length > 0 %}
                        <nav class="space-y-3">
                            {% for category in categories %}
                                <a href="{{ path('easy_faq_category_index', {"category" : category.slug}) }}"
                                   class="flex items-center justify-between p-3 text-gray-700 hover:text-emerald-600 hover:bg-emerald-50 rounded-lg transition-colors duration-200 group">
                                    <span class="font-medium">{{ category.name }}</span>
                                    <svg class="w-4 h-4 text-gray-400 group-hover:text-emerald-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </a>
                            {% endfor %}
                        </nav>
                    {% else %}
                        <p class="text-gray-500">No categories available</p>
                    {% endif %}

                    <!-- Quick Stats -->
                    <div class="mt-8 pt-6 border-t border-gray-200">
                        <h4 class="text-lg font-semibold text-gray-800 mb-4">FAQ Stats</h4>
                        <div class="space-y-3">
                            {% if entries is defined %}
                                <div class="flex justify-between items-center">
                                    <span class="text-gray-600">Total FAQs</span>
                                    <span class="font-semibold text-emerald-600">{{ entries|length }}</span>
                                </div>
                            {% endif %}
                            {% if categories is defined %}
                                <div class="flex justify-between items-center">
                                    <span class="text-gray-600">Categories</span>
                                    <span class="font-semibold text-emerald-600">{{ categories|length }}</span>
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <!-- Search -->
                    <div class="mt-8 pt-6 border-t border-gray-200">
                        <h4 class="text-lg font-semibold text-gray-800 mb-4">Search FAQs</h4>
                        <div class="relative">
                            <input type="search" placeholder="Search questions..."
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-transparent outline-none">
                            <div class="absolute inset-y-0 right-0 flex items-center pr-3">
                                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                </svg>
                            </div>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- FAQ Content -->
            <main class="lg:col-span-3">
                {% if entries is defined and entries|length > 0 %}
                    <div class="mb-8">
                        <h2 class="text-2xl font-bold text-gray-800 mb-2">Frequently Asked Questions</h2>
                        <p class="text-gray-600">Browse through our most commonly asked questions</p>
                    </div>

                    <!-- FAQ Accordion -->
                    <div class="space-y-4">
                        {% for entry in entries %}
                            <div class="bg-white rounded-lg shadow-md border border-gray-200">
                                <button class="w-full px-6 py-4 text-left flex items-center justify-between hover:bg-gray-50 transition-colors focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-inset"
                                        onclick="toggleFaq('faq-{{ loop.index }}')">
                                    <h3 class="text-lg font-semibold text-gray-800 pr-4">{{ entry.name }}</h3>
                                    <div class="flex items-center space-x-2">
                                        {% if entry.category %}
                                            <span class="inline-block bg-emerald-100 text-emerald-800 text-xs font-medium px-2.5 py-0.5 rounded-full">
                                                {{ entry.category.name }}
                                            </span>
                                        {% endif %}
                                        <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                                        </svg>
                                    </div>
                                </button>

                                <div id="faq-{{ loop.index }}" class="hidden px-6 pb-6">
                                    <div class="pt-4 border-t border-gray-100">
                                        <div class="prose max-w-none text-gray-700">
                                            {{ entry.answer|raw }}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <!-- Empty State -->
                    <div class="text-center py-16">
                        <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <h3 class="text-xl font-semibold text-gray-800 mb-2">No FAQs Available</h3>
                        <p class="text-gray-600">Check back later for frequently asked questions.</p>
                    </div>
                {% endif %}
            </main>
        </div>
    </div>

    <!-- Help Section -->
    <section class="bg-gray-100 py-16">
        <div class="container mx-auto px-6">
            <div class="max-w-2xl mx-auto text-center">
                <h3 class="text-2xl font-bold text-gray-800 mb-4">Couldn't Find Your Answer?</h3>
                <p class="text-gray-600 mb-8">Our support team is here to help you with any questions you might have.</p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="#" class="px-6 py-3 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors font-medium inline-flex items-center justify-center">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                        </svg>
                        Contact Support
                    </a>
                    <a href="#" class="px-6 py-3 border border-emerald-600 text-emerald-600 rounded-lg hover:bg-emerald-600 hover:text-white transition-colors font-medium inline-flex items-center justify-center">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a2 2 0 01-2-2v-1M7 9h2v6H7V9zm8 0h2v6h-2V9z"></path>
                        </svg>
                        Live Chat
                    </a>
                </div>
            </div>
        </div>
    </section>

    <script>
        function toggleFaq(id) {
            const element = document.getElementById(id);
            const button = element.previousElementSibling;
            const arrow = button.querySelector('svg:last-child');

            if (element.classList.contains('hidden')) {
                element.classList.remove('hidden');
                arrow.style.transform = 'rotate(180deg)';
            } else {
                element.classList.add('hidden');
                arrow.style.transform = 'rotate(0deg)';
            }
        }
    </script>
{% endblock %}
