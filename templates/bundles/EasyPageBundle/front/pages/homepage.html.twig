{% extends "@!EasyPage/front/pages/default.html.twig" %}

{% block title %}{{ page.name }} - Adeliom EasyAdmin Sandbox{% endblock %}

{% block easy_page_page_content %}
    <!-- Header Section -->
    <header class="bg-gradient-to-r from-blue-600 to-indigo-700 text-white">
        <div class="container mx-auto px-6 py-16">
            <div class="text-center">
                <h1 class="text-5xl font-bold mb-4">{{ page.name }}</h1>
                <p class="text-xl mb-8 text-blue-100">Welcome to the Adeliom EasyAdmin Sandbox</p>
                <p class="text-lg text-blue-200 max-w-2xl mx-auto">
                    Explore our comprehensive bundle ecosystem for Symfony applications.
                    This sandbox demonstrates the power and flexibility of our Easy* bundles.
                </p>
            </div>
        </div>
    </header>

    <!-- Navigation Menu Section -->
    <section class="py-16 bg-white">
        <div class="container mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold text-gray-800 mb-4">Site Navigation</h2>
                <p class="text-gray-600">Explore all sections of our website</p>
            </div>

            <!-- Main Menu -->
            {{ easy_menu('main') }}
        </div>
    </section>

    <!-- Features Section -->
    <section class="py-16 bg-gray-100">
        <div class="container mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold text-gray-800 mb-4">Easy* Bundle Ecosystem</h2>
                <p class="text-gray-600">Discover the power of our Symfony bundle collection</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="bg-white p-6 rounded-lg shadow-sm hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-blue-500 rounded-lg flex items-center justify-center mb-4">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold mb-2">EasyBlog</h3>
                    <p class="text-gray-600 text-sm">Complete blog system with categories, posts, and SEO optimization</p>
                </div>

                <div class="bg-white p-6 rounded-lg shadow-sm hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-green-500 rounded-lg flex items-center justify-center mb-4">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold mb-2">EasyMedia</h3>
                    <p class="text-gray-600 text-sm">Advanced media management with folders, metadata, and image processing</p>
                </div>

                <div class="bg-white p-6 rounded-lg shadow-sm hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-purple-500 rounded-lg flex items-center justify-center mb-4">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14-4H3m16 8H1m18 4H7"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold mb-2">EasyMenu</h3>
                    <p class="text-gray-600 text-sm">Hierarchical menu system with nested navigation support</p>
                </div>

                <div class="bg-white p-6 rounded-lg shadow-sm hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-orange-500 rounded-lg flex items-center justify-center mb-4">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold mb-2">EasyFAQ</h3>
                    <p class="text-gray-600 text-sm">FAQ management system with categories and search functionality</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Redirect Testing Section -->
    <section class="py-16 bg-yellow-50">
        <div class="container mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold text-gray-800 mb-4">EasyRedirect Testing</h2>
                <p class="text-gray-600">Test the redirect functionality by clicking on the links below</p>
                <div class="mt-4 p-4 bg-yellow-100 rounded-lg border border-yellow-200 max-w-3xl mx-auto">
                    <div class="flex items-start">
                        <svg class="w-5 h-5 text-yellow-600 mt-0.5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.99-.833-2.5 0L4.348 15.5c-.77.833.192 2.5 1.732 2.5z"></path>
                        </svg>
                        <div class="text-left">
                            <p class="text-sm text-yellow-800 font-medium mb-1">Testing Note</p>
                            <p class="text-sm text-yellow-700">These links demonstrate the EasyRedirect bundle in action. Each link will redirect you to its target destination.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Permanent Redirects (301) -->
                <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
                    <div class="flex items-center mb-4">
                        <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center mr-3">
                            <span class="text-white text-sm font-bold">301</span>
                        </div>
                        <h3 class="text-lg font-semibold text-gray-800">Permanent Redirects</h3>
                    </div>
                    <div class="space-y-3">
                        <div class="border border-gray-100 rounded-lg p-3 hover:bg-gray-50 transition-colors">
                            <a href="/old-homepage" class="block text-blue-600 hover:text-blue-800 font-medium">
                                /old-homepage
                            </a>
                            <p class="text-xs text-gray-500 mt-1">→ Homepage (15 hits)</p>
                        </div>
                        <div class="border border-gray-100 rounded-lg p-3 hover:bg-gray-50 transition-colors">
                            <a href="/old-about" class="block text-blue-600 hover:text-blue-800 font-medium">
                                /old-about
                            </a>
                            <p class="text-xs text-gray-500 mt-1">→ About page (8 hits)</p>
                        </div>
                        <div class="border border-gray-100 rounded-lg p-3 hover:bg-gray-50 transition-colors">
                            <a href="/legacy-blog" class="block text-blue-600 hover:text-blue-800 font-medium">
                                /legacy-blog
                            </a>
                            <p class="text-xs text-gray-500 mt-1">→ Blog section (23 hits)</p>
                        </div>
                        <div class="border border-gray-100 rounded-lg p-3 hover:bg-gray-50 transition-colors">
                            <a href="/old-contact-us" class="block text-blue-600 hover:text-blue-800 font-medium">
                                /old-contact-us
                            </a>
                            <p class="text-xs text-gray-500 mt-1">→ Contact page (5 hits)</p>
                        </div>
                    </div>
                </div>

                <!-- Temporary Redirects & External Links -->
                <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
                    <div class="flex items-center mb-4">
                        <div class="w-8 h-8 bg-orange-500 rounded-full flex items-center justify-center mr-3">
                            <span class="text-white text-sm font-bold">302</span>
                        </div>
                        <h3 class="text-lg font-semibold text-gray-800">Temporary & External</h3>
                    </div>
                    <div class="space-y-3">
                        <div class="border border-gray-100 rounded-lg p-3 hover:bg-gray-50 transition-colors">
                            <a href="/maintenance" class="block text-orange-600 hover:text-orange-800 font-medium">
                                /maintenance
                            </a>
                            <p class="text-xs text-gray-500 mt-1">→ Under construction (45 hits)</p>
                        </div>
                        <div class="border border-gray-100 rounded-lg p-3 hover:bg-gray-50 transition-colors">
                            <a href="/github" class="block text-blue-600 hover:text-blue-800 font-medium" target="_blank">
                                /github
                                <svg class="inline w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                                </svg>
                            </a>
                            <p class="text-xs text-gray-500 mt-1">→ External GitHub (12 hits)</p>
                        </div>
                    </div>
                </div>

                <!-- Content Redirects -->
                <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
                    <div class="flex items-center mb-4">
                        <div class="w-8 h-8 bg-purple-500 rounded-full flex items-center justify-center mr-3">
                            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
                            </svg>
                        </div>
                        <h3 class="text-lg font-semibold text-gray-800">Content Redirects</h3>
                    </div>
                    <div class="space-y-3">
                        <div class="border border-gray-100 rounded-lg p-3 hover:bg-gray-50 transition-colors">
                            <a href="/blog/old-post-slug" class="block text-purple-600 hover:text-purple-800 font-medium">
                                /blog/old-post-slug
                            </a>
                            <p class="text-xs text-gray-500 mt-1">→ New blog post (7 hits)</p>
                        </div>
                        <div class="border border-gray-100 rounded-lg p-3 hover:bg-gray-50 transition-colors">
                            <a href="/articles/symfony-tips" class="block text-purple-600 hover:text-purple-800 font-medium">
                                /articles/symfony-tips
                            </a>
                            <p class="text-xs text-gray-500 mt-1">→ Blog Symfony tips (19 hits)</p>
                        </div>
                        <div class="border border-gray-100 rounded-lg p-3 hover:bg-gray-50 transition-colors">
                            <a href="/category/tech" class="block text-purple-600 hover:text-purple-800 font-medium">
                                /category/tech
                            </a>
                            <p class="text-xs text-gray-500 mt-1">→ Technology category (34 hits)</p>
                        </div>
                        <div class="border border-gray-100 rounded-lg p-3 hover:bg-gray-50 transition-colors">
                            <a href="/faq/old-category" class="block text-purple-600 hover:text-purple-800 font-medium">
                                /faq/old-category
                            </a>
                            <p class="text-xs text-gray-500 mt-1">→ FAQ general questions (6 hits)</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Redirect Statistics -->
            <div class="mt-12 bg-white rounded-lg shadow-sm border border-gray-200 p-6">
                <h3 class="text-xl font-semibold text-gray-800 mb-6 text-center">Redirect Statistics</h3>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                    <div class="text-center">
                        <div class="text-3xl font-bold text-green-600 mb-2">10</div>
                        <div class="text-sm text-gray-600">Active Redirects</div>
                    </div>
                    <div class="text-center">
                        <div class="text-3xl font-bold text-blue-600 mb-2">149</div>
                        <div class="text-sm text-gray-600">Total Hits</div>
                    </div>
                    <div class="text-center">
                        <div class="text-3xl font-bold text-orange-600 mb-2">5</div>
                        <div class="text-sm text-gray-600">404 Errors Logged</div>
                    </div>
                    <div class="text-center">
                        <div class="text-3xl font-bold text-purple-600 mb-2">90%</div>
                        <div class="text-sm text-gray-600">Success Rate</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer Menu Section -->
    <section class="py-12 bg-gray-800 text-white">
        <div class="container mx-auto px-6">
            <div class="text-center mb-8">
                <h3 class="text-xl font-semibold mb-4">Quick Links</h3>
            </div>

            {{ easy_menu('footer') }}

            <div class="text-center mt-8 pt-8 border-t border-gray-700">
                <p class="text-gray-400">© 2024 Adeliom. Built with EasyAdmin Bundle Ecosystem.</p>
            </div>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ easy_block_assets() }}
    {{ easy_editor_assets() }}
{% endblock %}
