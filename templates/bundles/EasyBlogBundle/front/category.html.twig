{% extends '@!EasyBlog/front/category.html.twig' %}

{% block title %}{{ category.name }} - Blog - Adeliom EasyAdmin Sandbox{% endblock %}

{% block easy_page_page_content %}
    <!-- Category Header -->
    <header class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white">
        <div class="container mx-auto px-6 py-16">
            <div class="max-w-3xl">
                <!-- Breadcrumb -->
                <nav class="mb-6">
                    <ol class="flex items-center space-x-2 text-indigo-100">
                        <li><a href="{{ path('easy_blog_category_index') }}" class="hover:text-white transition-colors">Blog</a></li>
                        <li>
                            <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                            </svg>
                        </li>
                        <li class="text-white font-medium">{{ category.name }}</li>
                    </ol>
                </nav>

                <h1 class="text-4xl font-bold mb-4">{{ category.name }}</h1>
                {% if category.seo and category.seo.description %}
                    <p class="text-xl text-indigo-100">{{ category.seo.description }}</p>
                {% endif %}

                <div class="mt-6 flex items-center space-x-6 text-indigo-200">
                    {% if posts is defined %}
                        <div class="flex items-center">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
                            </svg>
                            {{ posts|length }} {{ posts|length == 1 ? 'post' : 'posts' }}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <div class="container mx-auto px-6 py-12">
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
            <!-- Posts Content -->
            <main class="lg:col-span-3">
                {% if posts is defined and posts|length > 0 %}
                    <!-- Filter/Sort Bar -->
                    <div class="flex items-center justify-between mb-8 pb-4 border-b border-gray-200">
                        <p class="text-gray-600">
                            Showing {{ posts|length }} {{ posts|length == 1 ? 'post' : 'posts' }} in <strong>{{ category.name }}</strong>
                        </p>
                        <div class="flex items-center space-x-4">
                            <select class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none">
                                <option>Newest First</option>
                                <option>Oldest First</option>
                                <option>Most Popular</option>
                            </select>
                        </div>
                    </div>

                    <!-- Posts List -->
                    <div class="space-y-8">
                        {% for post in posts %}
                            <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300">
                                <div class="md:flex">
                                    <!-- Post Image Placeholder -->
                                    <div class="md:w-1/3 bg-gradient-to-br from-indigo-100 to-purple-100 flex items-center justify-center h-48 md:h-auto">
                                        <svg class="w-16 h-16 text-indigo-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                        </svg>
                                    </div>

                                    <!-- Post Content -->
                                    <div class="md:w-2/3 p-6">
                                        <div class="flex items-center mb-3">
                                            {% if post.publishDate %}
                                                <time class="text-sm text-gray-500 flex items-center">
                                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                                    </svg>
                                                    {{ post.publishDate|date('F j, Y') }}
                                                </time>
                                            {% endif %}
                                            <span class="ml-auto text-sm text-gray-500">5 min read</span>
                                        </div>

                                        <h3 class="text-xl font-bold text-gray-800 mb-3 hover:text-indigo-600 transition-colors">
                                            <a href="{{ path('easy_blog_post_index', {"category" : post.category.slug, "post" : post.slug}) }}">
                                                {{ post.name }}
                                            </a>
                                        </h3>

                                        {% if post.seo and post.seo.description %}
                                            <p class="text-gray-600 mb-4 line-clamp-2">{{ post.seo.description }}</p>
                                        {% else %}
                                            <p class="text-gray-600 mb-4">{{ post.name|slice(0, 150) }}...</p>
                                        {% endif %}

                                        <div class="flex items-center justify-between">
                                            <a href="{{ path('easy_blog_post_index', {"category" : post.category.slug, "post" : post.slug}) }}"
                                               class="inline-flex items-center text-indigo-600 hover:text-indigo-800 font-medium transition-colors">
                                                Read Full Article
                                                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                                </svg>
                                            </a>

                                            <div class="flex items-center space-x-4 text-sm text-gray-500">
                                                <button class="flex items-center hover:text-indigo-600 transition-colors">
                                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                                                    </svg>
                                                    12
                                                </button>
                                                <button class="flex items-center hover:text-indigo-600 transition-colors">
                                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                                                    </svg>
                                                    3
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </article>
                        {% endfor %}
                    </div>

                    <!-- Pagination -->
                    <div class="mt-12 flex justify-center">
                        <div class="flex space-x-2">
                            <button class="px-4 py-2 text-indigo-600 border border-indigo-600 rounded-lg hover:bg-indigo-600 hover:text-white transition-colors">
                                Previous
                            </button>
                            <button class="px-4 py-2 bg-indigo-600 text-white rounded-lg">1</button>
                            <button class="px-4 py-2 text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-100 transition-colors">2</button>
                            <button class="px-4 py-2 text-indigo-600 border border-indigo-600 rounded-lg hover:bg-indigo-600 hover:text-white transition-colors">
                                Next
                            </button>
                        </div>
                    </div>
                {% else %}
                    <!-- Empty State -->
                    <div class="text-center py-16">
                        <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
                        </svg>
                        <h3 class="text-xl font-semibold text-gray-800 mb-2">No Posts in This Category</h3>
                        <p class="text-gray-600 mb-6">There are no published posts in the {{ category.name }} category yet.</p>
                        <a href="{{ path('easy_blog_category_index') }}"
                           class="inline-flex items-center px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors">
                            Browse All Posts
                        </a>
                    </div>
                {% endif %}
            </main>

            <!-- Sidebar -->
            <aside class="lg:col-span-1">
                <div class="space-y-6">
                    <!-- Back to Blog -->
                    <div class="bg-white rounded-lg shadow-md p-6">
                        <a href="{{ path('easy_blog_category_index') }}"
                           class="inline-flex items-center text-indigo-600 hover:text-indigo-800 font-medium transition-colors">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                            </svg>
                            Back to All Posts
                        </a>
                    </div>

                    <!-- Category Info -->
                    <div class="bg-white rounded-lg shadow-md p-6">
                        <h3 class="text-lg font-semibold text-gray-800 mb-4">About This Category</h3>
                        {% if category.seo and category.seo.description %}
                            <p class="text-gray-600 text-sm">{{ category.seo.description }}</p>
                        {% else %}
                            <p class="text-gray-600 text-sm">Explore articles related to {{ category.name }}.</p>
                        {% endif %}
                    </div>

                    <!-- Related Categories -->
                    {% if categories is defined and categories|length > 1 %}
                        <div class="bg-white rounded-lg shadow-md p-6">
                            <h3 class="text-lg font-semibold text-gray-800 mb-4">Other Categories</h3>
                            <div class="space-y-2">
                                {% for cat in categories %}
                                    {% if cat.slug != category.slug %}
                                        <a href="{{ path('easy_blog_category_index', {"category" : cat.slug}) }}"
                                           class="block p-2 text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 rounded transition-colors">
                                            {{ cat.name }}
                                        </a>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                </div>
            </aside>
        </div>
    </div>
{% endblock %}
