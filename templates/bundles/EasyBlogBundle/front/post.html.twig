{% extends '@!EasyBlog/front/post.html.twig' %}

{% block title %}{{ post.name }} - {{ post.category.name }} - Blog - Adeliom EasyAdmin Sandbox{% endblock %}

{% block easy_page_page_content %}
    <!-- Article Header -->
    <header class="bg-white border-b border-gray-200">
        <div class="container mx-auto px-6 py-8">
            <div class="max-w-4xl mx-auto">
                <!-- Breadcrumb -->
                <nav class="mb-6">
                    <ol class="flex items-center space-x-2 text-sm text-gray-500">
                        <li><a href="{{ path('easy_blog_category_index') }}" class="hover:text-indigo-600 transition-colors">Blog</a></li>
                        <li>
                            <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                            </svg>
                        </li>
                        <li><a href="{{ path('easy_blog_category_index', {"category" : post.category.slug}) }}" class="hover:text-indigo-600 transition-colors">{{ post.category.name }}</a></li>
                        <li>
                            <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                            </svg>
                        </li>
                        <li class="text-gray-800 font-medium">{{ post.name }}</li>
                    </ol>
                </nav>

                <!-- Article Meta -->
                <div class="mb-6">
                    <span class="inline-block bg-indigo-100 text-indigo-800 text-sm font-medium px-3 py-1 rounded-full mb-4">
                        {{ post.category.name }}
                    </span>

                    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4 leading-tight">{{ post.name }}</h1>

                    {% if post.seo and post.seo.description %}
                        <p class="text-xl text-gray-600 leading-relaxed">{{ post.seo.description }}</p>
                    {% endif %}
                </div>

                <!-- Article Info -->
                <div class="flex flex-wrap items-center justify-between py-6 border-t border-b border-gray-200">
                    <div class="flex items-center space-x-6">
                        <!-- Author -->
                        <div class="flex items-center">
                            <div class="w-12 h-12 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-full flex items-center justify-center text-white font-bold text-lg mr-3">
                                A
                            </div>
                            <div>
                                <p class="text-sm font-medium text-gray-900">Adeliom Team</p>
                                <p class="text-sm text-gray-500">Content Author</p>
                            </div>
                        </div>

                        <!-- Date -->
                        {% if post.publishDate %}
                            <div class="flex items-center text-gray-500">
                                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                                <time datetime="{{ post.publishDate|date('c') }}">{{ post.publishDate|date('F j, Y') }}</time>
                            </div>
                        {% endif %}

                        <!-- Reading time -->
                        <div class="flex items-center text-gray-500">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                            </svg>
                            <span>8 min read</span>
                        </div>
                    </div>

                    <!-- Social sharing -->
                    <div class="flex items-center space-x-3 mt-4 sm:mt-0">
                        <span class="text-sm text-gray-500">Share:</span>
                        <button class="w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center hover:bg-blue-700 transition-colors">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
                            </svg>
                        </button>
                        <button class="w-8 h-8 bg-blue-800 text-white rounded-full flex items-center justify-center hover:bg-blue-900 transition-colors">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.03c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"/>
                            </svg>
                        </button>
                        <button class="w-8 h-8 bg-blue-700 text-white rounded-full flex items-center justify-center hover:bg-blue-800 transition-colors">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Article Content -->
    <article class="py-12">
        <div class="container mx-auto px-6">
            <div class="max-w-4xl mx-auto">
                <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
                    <!-- Main Content -->
                    <div class="lg:col-span-3">
                        <!-- Featured Image Placeholder -->
                        <div class="bg-gradient-to-br from-indigo-100 to-purple-100 rounded-lg h-64 md:h-80 flex items-center justify-center mb-8">
                            <svg class="w-24 h-24 text-indigo-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                        </div>

                        <!-- Article Body -->
                        <div class="prose prose-lg max-w-none">
                            <p class="lead text-xl text-gray-700 mb-6">
                                This is a sample blog post demonstrating the EasyBlog bundle capabilities.
                                In a real implementation, this content would come from your post content management system.
                            </p>

                            <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Introduction</h2>
                            <p class="text-gray-700 mb-6 leading-relaxed">
                                Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
                                Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
                            </p>

                            <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Key Features</h2>
                            <ul class="list-disc list-inside text-gray-700 mb-6 space-y-2">
                                <li>Responsive design using Tailwind CSS</li>
                                <li>SEO optimization with meta tags</li>
                                <li>Category-based organization</li>
                                <li>Social sharing capabilities</li>
                                <li>Related posts suggestions</li>
                            </ul>

                            <blockquote class="border-l-4 border-indigo-500 pl-6 my-8 italic text-gray-700 bg-gray-50 py-4">
                                "The EasyBlog bundle provides a complete blogging solution for Symfony applications,
                                with all the features you need to create engaging content."
                            </blockquote>

                            <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Implementation Details</h2>
                            <p class="text-gray-700 mb-6 leading-relaxed">
                                Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.
                                Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.
                            </p>

                            <div class="bg-gray-100 rounded-lg p-6 my-8">
                                <h3 class="text-lg font-semibold text-gray-900 mb-3">Code Example</h3>
                                <pre class="bg-gray-800 text-green-400 p-4 rounded text-sm overflow-x-auto"><code>// Example of using EasyBlog in a controller
class BlogController extends AbstractController
{
    #[Route('/blog', name: 'blog_index')]
    public function index(): Response
    {
        return $this->render('blog/index.html.twig');
    }
}</code></pre>
                            </div>

                            <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Conclusion</h2>
                            <p class="text-gray-700 mb-6 leading-relaxed">
                                Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium,
                                totam rem aperiam, eaque ipsa quae ab illo inventore veritatis et quasi architecto beatae vitae dicta sunt explicabo.
                            </p>
                        </div>

                        <!-- Article Tags -->
                        <div class="mt-8 pt-8 border-t border-gray-200">
                            <h3 class="text-lg font-semibold text-gray-900 mb-4">Tags</h3>
                            <div class="flex flex-wrap gap-2">
                                <span class="px-3 py-1 bg-gray-100 text-gray-800 text-sm rounded-full">Symfony</span>
                                <span class="px-3 py-1 bg-gray-100 text-gray-800 text-sm rounded-full">EasyBlog</span>
                                <span class="px-3 py-1 bg-gray-100 text-gray-800 text-sm rounded-full">{{ post.category.name }}</span>
                                <span class="px-3 py-1 bg-gray-100 text-gray-800 text-sm rounded-full">Tutorial</span>
                            </div>
                        </div>

                        <!-- SEO Information Section -->
                        {% if post.seo %}
                            <div class="mt-12 pt-8 border-t border-gray-200">
                                <h3 class="text-2xl font-bold text-gray-900 mb-6 flex items-center">
                                    <svg class="w-6 h-6 mr-3 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                                    </svg>
                                    SEO Information
                                </h3>
                                
                                <div class="bg-gradient-to-r from-indigo-50 to-purple-50 rounded-lg border border-indigo-200 p-6">
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <!-- SEO Title -->
                                        {% if post.seo.title %}
                                            <div>
                                                <h4 class="text-sm font-semibold text-gray-700 mb-2 flex items-center">
                                                    <svg class="w-4 h-4 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                                                    </svg>
                                                    SEO Title
                                                </h4>
                                                <p class="text-gray-800 bg-white rounded px-3 py-2 border">{{ post.seo.title }}</p>
                                            </div>
                                        {% endif %}
                                        
                                        <!-- Meta Description -->
                                        {% if post.seo.description %}
                                            <div>
                                                <h4 class="text-sm font-semibold text-gray-700 mb-2 flex items-center">
                                                    <svg class="w-4 h-4 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                                    </svg>
                                                    Meta Description
                                                </h4>
                                                <p class="text-gray-800 bg-white rounded px-3 py-2 border">{{ post.seo.description }}</p>
                                            </div>
                                        {% endif %}
                                        
                                        <!-- Keywords -->
                                        {% if post.seo.keywords %}
                                            <div>
                                                <h4 class="text-sm font-semibold text-gray-700 mb-2 flex items-center">
                                                    <svg class="w-4 h-4 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path>
                                                    </svg>
                                                    Keywords
                                                </h4>
                                                <div class="bg-white rounded px-3 py-2 border">
                                                    {% set keywords = post.seo.keywords|split(',') %}
                                                    {% for keyword in keywords %}
                                                        <span class="inline-block bg-indigo-100 text-indigo-800 text-xs px-2 py-1 rounded-full mr-1 mb-1">
                                                            {{ keyword|trim }}
                                                        </span>
                                                    {% endfor %}
                                                </div>
                                            </div>
                                        {% endif %}
                                        
                                        <!-- Canonical URL -->
                                        {% if post.seo.cannonical %}
                                            <div>
                                                <h4 class="text-sm font-semibold text-gray-700 mb-2 flex items-center">
                                                    <svg class="w-4 h-4 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                                                    </svg>
                                                    Canonical URL
                                                </h4>
                                                <p class="text-gray-800 bg-white rounded px-3 py-2 border font-mono text-sm break-all">{{ post.seo.cannonical }}</p>
                                            </div>
                                        {% endif %}
                                        
                                        <!-- Robots Meta -->
                                        {% if post.seo.robots %}
                                            <div>
                                                <h4 class="text-sm font-semibold text-gray-700 mb-2 flex items-center">
                                                    <svg class="w-4 h-4 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                                    </svg>
                                                    Robots Meta
                                                </h4>
                                                <div class="bg-white rounded px-3 py-2 border">
                                                    {% for robot in post.seo.robots %}
                                                        <span class="inline-block bg-purple-100 text-purple-800 text-xs px-2 py-1 rounded-full mr-1 mb-1">
                                                            {{ robot }}
                                                        </span>
                                                    {% endfor %}
                                                </div>
                                            </div>
                                        {% endif %}
                                        
                                        <!-- Sitemap Inclusion -->
                                        <div>
                                            <h4 class="text-sm font-semibold text-gray-700 mb-2 flex items-center">
                                                <svg class="w-4 h-4 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 6m0 14l6-3m-6 3V6m6 9l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 5m0 14V5"></path>
                                                    </svg>
                                                Sitemap Inclusion
                                            </h4>
                                            <span class="inline-flex items-center px-3 py-2 rounded-md text-sm font-medium {{ post.seo.sitemap ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' }}">
                                                {% if post.seo.sitemap %}
                                                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                                    </svg>
                                                    Included
                                                {% else %}
                                                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                                    </svg>
                                                    Excluded
                                                {% endif %}
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}

                        <!-- Comments Section -->
                        <div class="mt-12 pt-8 border-t border-gray-200">
                            <h3 class="text-2xl font-bold text-gray-900 mb-6">Comments</h3>
                            <div class="bg-gray-50 rounded-lg p-6 text-center">
                                <svg class="w-12 h-12 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                                </svg>
                                <p class="text-gray-600">Comments system would be integrated here</p>
                            </div>
                        </div>
                    </div>

                    <!-- Sidebar -->
                    <aside class="lg:col-span-1">
                        <div class="sticky top-6 space-y-6">
                            <!-- Navigation -->
                            <div class="bg-white rounded-lg shadow-md p-6">
                                <div class="space-y-3">
                                    <a href="{{ path('easy_blog_category_index') }}"
                                       class="flex items-center text-gray-600 hover:text-indigo-600 transition-colors">
                                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                                        </svg>
                                        All Posts
                                    </a>
                                    <a href="{{ path('easy_blog_category_index', {"category" : post.category.slug}) }}"
                                       class="flex items-center text-gray-600 hover:text-indigo-600 transition-colors">
                                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                                        </svg>
                                        {{ post.category.name }}
                                    </a>
                                </div>
                            </div>

                            <!-- Table of Contents -->
                            <div class="bg-white rounded-lg shadow-md p-6">
                                <h4 class="text-lg font-semibold text-gray-900 mb-4">Table of Contents</h4>
                                <nav class="space-y-2">
                                    <a href="#introduction" class="block text-sm text-gray-600 hover:text-indigo-600 transition-colors">Introduction</a>
                                    <a href="#key-features" class="block text-sm text-gray-600 hover:text-indigo-600 transition-colors">Key Features</a>
                                    <a href="#implementation" class="block text-sm text-gray-600 hover:text-indigo-600 transition-colors">Implementation Details</a>
                                    <a href="#conclusion" class="block text-sm text-gray-600 hover:text-indigo-600 transition-colors">Conclusion</a>
                                </nav>
                            </div>

                            <!-- Related Posts -->
                            <div class="bg-white rounded-lg shadow-md p-6">
                                <h4 class="text-lg font-semibold text-gray-900 mb-4">Related Posts</h4>
                                <div class="space-y-4">
                                    <div class="border-b border-gray-200 pb-4">
                                        <h5 class="font-medium text-gray-900 mb-1 hover:text-indigo-600 transition-colors">
                                            <a href="#">Getting Started with Symfony</a>
                                        </h5>
                                        <p class="text-sm text-gray-600">Learn the basics of Symfony framework...</p>
                                    </div>
                                    <div class="border-b border-gray-200 pb-4">
                                        <h5 class="font-medium text-gray-900 mb-1 hover:text-indigo-600 transition-colors">
                                            <a href="#">Advanced EasyAdmin Features</a>
                                        </h5>
                                        <p class="text-sm text-gray-600">Explore advanced administration features...</p>
                                    </div>
                                    <div>
                                        <h5 class="font-medium text-gray-900 mb-1 hover:text-indigo-600 transition-colors">
                                            <a href="#">Building Modern Web Apps</a>
                                        </h5>
                                        <p class="text-sm text-gray-600">Best practices for modern development...</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        </div>
    </article>
{% endblock %}
