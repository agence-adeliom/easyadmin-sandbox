{#
    SEO Debug Component

    Include this in any page template to display SEO metadata for debugging.
    Only displays in dev environment.

    Usage: {% include 'components/_seo_debug.html.twig' with { seo: page.seo } %}
    Or with a custom entity: {% include 'components/_seo_debug.html.twig' with { seo: post.seo } %}
#}

{% if app.debug %}
<div id="seo-debug-panel" class="fixed bottom-12 right-4 z-50">
    <button
        onclick="document.getElementById('seo-debug-content').classList.toggle('hidden')"
        class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg shadow-lg flex items-center gap-2 transition-colors"
    >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
        </svg>
        SEO Debug
    </button>

    <div id="seo-debug-content" class="hidden absolute bottom-12 right-0 w-96 max-h-[80vh] overflow-y-auto bg-white rounded-lg shadow-2xl border border-gray-200">
        <div class="sticky top-0 bg-indigo-600 text-white px-4 py-3 rounded-t-lg flex justify-between items-center">
            <h3 class="font-semibold flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                </svg>
                SEO Metadata
            </h3>
            <button onclick="document.getElementById('seo-debug-content').classList.add('hidden')" class="text-white hover:text-gray-200">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>

        <div class="p-4 space-y-4">
            {% if seo is not defined or seo is null %}
                <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-3">
                    <p class="text-yellow-800 text-sm flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                        </svg>
                        No SEO data available for this page
                    </p>
                </div>
            {% else %}
                {# Title #}
                <div class="border-b border-gray-100 pb-3">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Title</span>
                        {% if seo.title %}
                            {% set title_length = seo.title|length %}
                            <span class="text-xs px-2 py-0.5 rounded-full {{ title_length >= 30 and title_length <= 65 ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' }}">
                                {{ title_length }} chars (30-65)
                            </span>
                        {% endif %}
                    </div>
                    <p class="text-sm text-gray-800 {{ seo.title ? '' : 'italic text-gray-400' }}">
                        {{ seo.title ?: 'Not set' }}
                    </p>
                </div>

                {# Description #}
                <div class="border-b border-gray-100 pb-3">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Description</span>
                        {% if seo.description %}
                            {% set desc_length = seo.description|length %}
                            <span class="text-xs px-2 py-0.5 rounded-full {{ desc_length >= 120 and desc_length <= 155 ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' }}">
                                {{ desc_length }} chars (120-155)
                            </span>
                        {% endif %}
                    </div>
                    <p class="text-sm text-gray-800 {{ seo.description ? '' : 'italic text-gray-400' }}">
                        {{ seo.description ?: 'Not set' }}
                    </p>
                </div>

                {# Keywords #}
                <div class="border-b border-gray-100 pb-3">
                    <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">Keywords</span>
                    {% if seo.keywords %}
                        <div class="flex flex-wrap gap-1">
                            {% for keyword in seo.keywords|split(',') %}
                                <span class="inline-block bg-indigo-100 text-indigo-700 text-xs px-2 py-0.5 rounded">
                                    {{ keyword|trim }}
                                </span>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-sm italic text-gray-400">Not set</p>
                    {% endif %}
                </div>

                {# Canonical URL #}
                <div class="border-b border-gray-100 pb-3">
                    <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">Canonical URL</span>
                    <p class="text-sm {{ seo.cannonical ? 'text-blue-600 break-all' : 'italic text-gray-400' }}">
                        {{ seo.cannonical ?: 'Not set' }}
                    </p>
                </div>

                {# Page Key #}
                <div class="border-b border-gray-100 pb-3">
                    <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">Page Key</span>
                    <p class="text-sm {{ seo.key ? 'font-mono bg-gray-100 px-2 py-1 rounded' : 'italic text-gray-400' }}">
                        {{ seo.key ?: 'Not set' }}
                    </p>
                </div>

                {# Robots #}
                <div class="border-b border-gray-100 pb-3">
                    <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">Robots</span>
                    {% if seo.robots is not empty %}
                        <div class="flex flex-wrap gap-1">
                            {% for robot in seo.robots %}
                                <span class="inline-block bg-orange-100 text-orange-700 text-xs px-2 py-0.5 rounded">
                                    {{ robot }}
                                </span>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-sm text-green-600">Default (index, follow)</p>
                    {% endif %}
                </div>

                {# Sitemap #}
                <div class="border-b border-gray-100 pb-3">
                    <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">Sitemap</span>
                    <span class="inline-flex items-center gap-1 text-sm {{ seo.sitemap ? 'text-green-600' : 'text-red-600' }}">
                        {% if seo.sitemap %}
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                            Included
                        {% else %}
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                            Excluded
                        {% endif %}
                    </span>
                </div>

                {# Cover Image #}
                <div>
                    <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">OG Cover Image</span>
                    {% if seo.cover %}
                        {% set cover_url = seo.cover|resolve_media %}
                        {% if cover_url %}
                            <div class="mt-2">
                                <img src="{{ cover_url }}" alt="OG Cover" class="w-full h-32 object-cover rounded border border-gray-200">
                                <p class="text-xs text-gray-500 mt-1 break-all">{{ cover_url }}</p>
                            </div>
                        {% else %}
                            <p class="text-sm italic text-gray-400">Media not resolved</p>
                        {% endif %}
                    {% else %}
                        <p class="text-sm italic text-gray-400">Not set</p>
                    {% endif %}
                </div>
            {% endif %}
        </div>

        <div class="bg-gray-50 px-4 py-2 text-xs text-gray-500 border-t border-gray-200 rounded-b-lg">
            This panel is only visible in dev mode
        </div>
    </div>
</div>
{% endif %}
