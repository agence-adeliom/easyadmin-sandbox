<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>System Configuration - Adeliom EasyAdmin Sandbox</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">

    <!-- Header Section -->
    <header class="bg-gradient-to-r from-gray-700 to-gray-900 text-white">
        <div class="container mx-auto px-6 py-16">
            <div class="text-center">
                <h1 class="text-4xl font-bold mb-4">System Configuration</h1>
                <p class="text-xl text-gray-300">EasyConfig Bundle - Database Stored Settings</p>
                <div class="mt-4 inline-flex items-center px-4 py-2 bg-gray-600 rounded-lg">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                    <span class="font-semibold">{{ totalConfigs }} Configuration{{ totalConfigs != 1 ? 's' }} Found</span>
                </div>
            </div>
        </div>
    </header>

    <!-- Navigation -->
    <div class="bg-white border-b border-gray-200">
        <div class="container mx-auto px-6">
            <nav class="flex items-center py-4 text-sm">
                <a href="/" class="text-blue-600 hover:text-blue-800">Homepage</a>
                <svg class="w-4 h-4 mx-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
                <span class="text-gray-700">System Configuration</span>
            </nav>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container mx-auto px-6 py-12">
        <!-- Summary Cards -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-12">
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 text-center">
                <div class="text-3xl font-bold text-blue-600 mb-2">{{ totalConfigs }}</div>
                <div class="text-sm text-blue-800">Total Configurations</div>
            </div>
            <div class="bg-green-50 border border-green-200 rounded-lg p-6 text-center">
                <div class="text-3xl font-bold text-green-600 mb-2">{{ groupedConfigs|length }}</div>
                <div class="text-sm text-green-800">Categories</div>
            </div>
            <div class="bg-purple-50 border border-purple-200 rounded-lg p-6 text-center">
                <div class="text-3xl font-bold text-purple-600 mb-2">
                    {% set uniqueTypes = [] %}
                    {% for config in configs %}
                        {% if config.type not in uniqueTypes %}
                            {% set uniqueTypes = uniqueTypes|merge([config.type]) %}
                        {% endif %}
                    {% endfor %}
                    {{ uniqueTypes|length }}
                </div>
                <div class="text-sm text-purple-800">Data Types</div>
            </div>
            <div class="bg-orange-50 border border-orange-200 rounded-lg p-6 text-center">
                <div class="text-3xl font-bold text-orange-600 mb-2">✓</div>
                <div class="text-sm text-orange-800">All Loaded</div>
            </div>
        </div>

        <!-- Configuration Groups -->
        {% for groupName, groupConfigs in groupedConfigs %}
            <div class="bg-white rounded-lg shadow-md border border-gray-200 mb-8">
                <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 rounded-t-lg">
                    <h2 class="text-xl font-semibold text-gray-800 flex items-center">
                        {% if groupName == 'Site Information' %}
                            <svg class="w-5 h-5 mr-3 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0-9v9m0 9c-5 0-9-4-9-9s4-9 9-9"></path>
                            </svg>
                        {% elseif groupName == 'Contact Information' %}
                            <svg class="w-5 h-5 mr-3 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                            </svg>
                        {% elseif groupName == 'Social Media' %}
                            <svg class="w-5 h-5 mr-3 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4V2a1 1 0 011-1h8a1 1 0 011 1v2m-9 3v10a1 1 0 001 1h8a1 1 0 001-1V7H7z"></path>
                            </svg>
                        {% elseif groupName == 'Features' %}
                            <svg class="w-5 h-5 mr-3 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4"></path>
                            </svg>
                        {% elseif groupName == 'Appearance' %}
                            <svg class="w-5 h-5 mr-3 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zM21 5a2 2 0 00-2-2h-4a2 2 0 00-2 2v12a4 4 0 004 4h4a2 2 0 002-2V5z"></path>
                            </svg>
                        {% else %}
                            <svg class="w-5 h-5 mr-3 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                        {% endif %}
                        {{ groupName }}
                        <span class="ml-auto text-sm font-normal text-gray-500">({{ groupConfigs|length }} item{{ groupConfigs|length != 1 ? 's' }})</span>
                    </h2>
                </div>

                <div class="p-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        {% for config in groupConfigs %}
                            <div class="border border-gray-200 rounded-lg p-4 hover:border-gray-300 transition-colors">
                                <div class="flex items-start justify-between mb-3">
                                    <div class="flex-1">
                                        <h3 class="font-semibold text-gray-800">{{ config.name }}</h3>
                                        <p class="text-sm text-gray-600 mt-1">{{ config.description }}</p>
                                    </div>
                                    <div class="ml-4">
                                        {% set typeClass = config.type == 'boolean' ? 'bg-green-100 text-green-800' :
                                                          config.type == 'number' ? 'bg-blue-100 text-blue-800' :
                                                          config.type == 'color' ? 'bg-pink-100 text-pink-800' :
                                                          config.type == 'json' ? 'bg-purple-100 text-purple-800' :
                                                          config.type == 'wysiwyg' ? 'bg-orange-100 text-orange-800' :
                                                          'bg-gray-100 text-gray-800' %}
                                        <span class="inline-block px-2 py-1 text-xs font-medium rounded {{ typeClass }}">
                                            {{ config.type|upper }}
                                        </span>
                                    </div>
                                </div>

                                <div class="space-y-2">
                                    <div class="flex items-center text-sm">
                                        <span class="font-medium text-gray-700 w-16">Key:</span>
                                        <code class="bg-gray-100 px-2 py-1 rounded text-xs font-mono">{{ config.key }}</code>
                                    </div>

                                    <div class="flex items-start text-sm">
                                        <span class="font-medium text-gray-700 w-16 flex-shrink-0">Value:</span>
                                        <div class="flex-1 ml-2">
                                            {% if config.type == 'boolean' %}
                                                <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium {{ config.value == '1' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' }}">
                                                    {% if config.value == '1' %}
                                                        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                                        </svg>
                                                        Enabled
                                                    {% else %}
                                                        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                                        </svg>
                                                        Disabled
                                                    {% endif %}
                                                </span>
                                            {% elseif config.type == 'color' %}
                                                <div class="flex items-center">
                                                    <div class="w-6 h-6 rounded border border-gray-300 mr-2" style="background-color: {{ config.value }}"></div>
                                                    <code class="bg-gray-100 px-2 py-1 rounded text-xs font-mono">{{ config.value }}</code>
                                                </div>
                                            {% elseif config.type == 'wysiwyg' %}
                                                <div class="bg-gray-50 p-2 rounded border max-h-20 overflow-y-auto">
                                                    {{ config.value|raw }}
                                                </div>
                                            {% elseif config.type == 'json' %}
                                                <div class="bg-gray-900 text-green-400 p-2 rounded text-xs font-mono max-h-20 overflow-y-auto">
                                                    {{ config.value|json_encode(constant('JSON_PRETTY_PRINT')) }}
                                                </div>
                                            {% elseif config.type == 'textarea' %}
                                                <div class="bg-gray-50 p-2 rounded border text-sm max-h-20 overflow-y-auto">
                                                    {{ config.value }}
                                                </div>
                                            {% else %}
                                                <code class="bg-gray-100 px-2 py-1 rounded text-sm font-mono break-all">{{ config.value }}</code>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endfor %}

        <!-- Raw Data Section -->
        <div class="bg-white rounded-lg shadow-md border border-gray-200">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 rounded-t-lg">
                <h2 class="text-xl font-semibold text-gray-800 flex items-center">
                    <svg class="w-5 h-5 mr-3 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                    Raw Configuration Data
                    <span class="ml-auto text-sm font-normal text-gray-500">For verification against fixtures</span>
                </h2>
            </div>

            <div class="p-6">
                <div class="bg-gray-900 text-green-400 p-4 rounded text-sm font-mono overflow-x-auto">
                    <pre>{% for config in configs %}{{ config.key }}: "{{ config.value }}" ({{ config.type }})
{% endfor %}</pre>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
