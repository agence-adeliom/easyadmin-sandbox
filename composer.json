{
    "name": "agence-adeliom/easyadmin-sandbox",
    "description": "A simple sandbox for Symfony 6 and Easyadmin with Adeliom's bundles",
    "license": "proprietary",
    "authors": [
        {
            "name": "Arnaud RITTI",
            "homepage": "https://github.com/arnaud-ritti"
        },
        {
            "name": "Jerome ENGELN",
            "homepage": "https://github.com/JeromeEngelnAdeliom"
        }
    ],
    "type": "project",
    "require": {
        "php": ">=8.0.2",
        "ext-ctype": "*",
        "ext-exif": "*",
        "ext-iconv": "*",
        "ext-json": "*",
        "babdev/pagerfanta-bundle": "^3.0",
        "doctrine/annotations": "^1.13.3",
        "doctrine/doctrine-bundle": "^2.7.0",
        "doctrine/doctrine-migrations-bundle": "^3.1",
        "doctrine/orm": "^2.13",
        "easycorp/easyadmin-bundle": "^3.4 || ^v4.0",
        "embed/embed": "^4.2",
        "friendsofsymfony/ckeditor-bundle": "^2.3",
        "illuminate/support": "^9.2",
        "james-heinrich/getid3": "^1.9",
        "league/flysystem-aws-s3-v3": "^3.10",
        "league/flysystem-bundle": "^3.0",
        "liip/imagine-bundle": "^2.8",
        "maennchen/zipstream-php": "^2.1.0",
        "nyholm/psr7": "^1.4",
        "pagerfanta/doctrine-orm-adapter": "^3.0",
        "pagerfanta/twig": "^3.0",
        "phpdocumentor/reflection-docblock": "^5.2 || ^6.0",
        "presta/sitemap-bundle": "^3.0",
        "sensio/framework-extra-bundle": "^6.1",
        "stof/doctrine-extensions-bundle": "^1.6",
        "symfony/apache-pack": "^1.0",
        "symfony/asset": "^5.4 || ^6.0",
        "symfony/config": "^5.4 || ^6.0",
        "symfony/console": "^5.4 || ^6.0",
        "symfony/dependency-injection": "^5.4 || ^6.0",
        "symfony/deprecation-contracts": "^2.2 || ^v3.0",
        "symfony/dotenv": "^5.4 || ^6.0",
        "symfony/event-dispatcher": "^5.4 || ^6.0",
        "symfony/expression-language": "^5.4 || ^6.0",
        "symfony/filesystem": "^5.4 || ^6.0",
        "symfony/flex": "^1.9.0",
        "symfony/form": "^5.4 || ^6.0",
        "symfony/framework-bundle": "^5.4 || ^6.0",
        "symfony/http-client": "^5.4 || ^6.0",
        "symfony/http-kernel": "^5.4 || ^6.0",
        "symfony/intl": "^5.4 || ^6.0",
        "symfony/mailer": "^5.4 || ^6.0",
        "symfony/mime": "^5.4 || ^6.0",
        "symfony/monolog-bundle": "^3.1",
        "symfony/notifier": "^5.4 || ^6.0",
        "symfony/options-resolver": "^5.4 || ^6.0",
        "symfony/password-hasher": "^5.4 || ^6.0",
        "symfony/process": "^5.4 || ^6.0",
        "symfony/property-access": "^5.4 || ^6.0",
        "symfony/property-info": "^5.4 || ^6.0",
        "symfony/proxy-manager-bridge": "^5.4 || ^6.0",
        "symfony/psr-http-message-bridge": "^2.0",
        "symfony/runtime": "^5.4 || ^6.0",
        "symfony/security-bundle": "^5.4 || ^6.0",
        "symfony/serializer": "^5.4 || ^6.0",
        "symfony/stopwatch": "^5.4 || ^6.0",
        "symfony/string": "^5.4 || ^6.0",
        "symfony/translation": "^5.4 || ^6.0",
        "symfony/twig-bundle": "^5.4 || ^6.0",
        "symfony/validator": "^5.4 || ^6.0",
        "symfony/web-link": "^5.4 || ^6.0",
        "symfony/webpack-encore-bundle": "^1.10",
        "symfony/yaml": "^5.4 || ^6.0",
        "symfonycasts/reset-password-bundle": "^1.8",
        "twig/twig": "^2.12|^3.0"
    },
    "require-dev": {
        "composer/package-versions-deprecated": "^1.11",
        "doctrine/doctrine-fixtures-bundle": "^3.4",
        "friendsofphp/php-cs-fixer": "^3.10",
        "nunomaduro/phpinsights": "^2.4",
        "phpunit/phpunit": "^9.5",
        "rector/rector": "^0.14.0",
        "symfony/browser-kit": "^5.4 || ^6.0",
        "symfony/css-selector": "^5.4 || ^6.0",
        "symfony/debug-bundle": "^5.4 || ^6.0",
        "symfony/maker-bundle": "^1.0",
        "symfony/phpunit-bridge": "^5.4 || ^6.0",
        "symfony/var-dumper": "^5.4 || ^6.0",
        "symfony/web-profiler-bundle": "^5.4 || ^6.0",
        "symplify/monorepo-builder": "^11.1"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "symfony/thanks": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "autoload": {
        "files": [
            "lib/easy-gutenberg-bundle/include/wp.php"
        ],
        "psr-4": {
            "Adeliom\\EasyAdminUserBundle\\": "lib/easy-admin-user-bundle/src/",
            "Adeliom\\EasyBlockBundle\\": "lib/easy-block-bundle/src/",
            "Adeliom\\EasyBlogBundle\\": "lib/easy-blog-bundle/src/",
            "Adeliom\\EasyCommonBundle\\": "lib/easy-common-bundle/src/",
            "Adeliom\\EasyConfigBundle\\": "lib/easy-config-bundle/src/",
            "Adeliom\\EasyEditorBundle\\": "lib/easy-editor-bundle/src/",
            "Adeliom\\EasyFaqBundle\\": "lib/easy-faq-bundle/src/",
            "Adeliom\\EasyFieldsBundle\\": "lib/easy-fields-bundle/src/",
            "Adeliom\\EasyGutenbergBundle\\": "lib/easy-gutenberg-bundle/src/",
            "Adeliom\\EasyMediaBundle\\": "lib/easy-media-bundle/src/",
            "Adeliom\\EasyMenuBundle\\": "lib/easy-menu-bundle/src/",
            "Adeliom\\EasyPageBundle\\": "lib/easy-page-bundle/src/",
            "Adeliom\\EasyRedirectBundle\\": "lib/easy-redirect-bundle/src/",
            "Adeliom\\EasySeoBundle\\": "lib/easy-seo-bundle/src/",
            "App\\": "src/",
            "MonorepoHelper\\": "monorepo-helpers/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "agence-adeliom/easy-admin-user-bundle": "self.version",
        "agence-adeliom/easy-block-bundle": "self.version",
        "agence-adeliom/easy-blog-bundle": "self.version",
        "agence-adeliom/easy-common-bundle": "self.version",
        "agence-adeliom/easy-config-bundle": "self.version",
        "agence-adeliom/easy-editor-bundle": "self.version",
        "agence-adeliom/easy-faq-bundle": "self.version",
        "agence-adeliom/easy-fields-bundle": "self.version",
        "agence-adeliom/easy-gutenberg-bundle": "self.version",
        "agence-adeliom/easy-media-bundle": "self.version",
        "agence-adeliom/easy-menu-bundle": "self.version",
        "agence-adeliom/easy-page-bundle": "self.version",
        "agence-adeliom/easy-redirect-bundle": "self.version",
        "agence-adeliom/easy-seo-bundle": "self.version"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "ckeditor:install --clear=drop": "symfony-cmd",
            "assets:install --symlink --relative %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "unit-tests": [
            "php bin/phpunit"
        ]
    },
    "extra": {
        "symfony": {
            "endpoint": [
                "https://api.github.com/repos/agence-adeliom/symfony-recipes/contents/index.json?ref=flex/main",
                "flex://defaults"
            ],
            "allow-contrib": true,
            "require": "6.0.*"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
