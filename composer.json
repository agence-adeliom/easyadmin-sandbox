{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "lib/EasyMediaBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyEditorBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyFieldsBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyCommonBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyPageBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyBlogBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasySeoBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyBlockBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyShopBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyFaqBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyMenuBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyAdminUserBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyConfigBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyRedirectBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "ext-ctype": "*",
        "ext-exif": "*",
        "ext-iconv": "*",
        "ext-json": "*",
        "agence-adeliom/easy-admin-user-bundle": "*",
        "agence-adeliom/easy-block-bundle": "*",
        "agence-adeliom/easy-blog-bundle": "*",
        "agence-adeliom/easy-common-bundle": "*",
        "agence-adeliom/easy-config-bundle": "*",
        "agence-adeliom/easy-editor-bundle": "*",
        "agence-adeliom/easy-faq-bundle": "*",
        "agence-adeliom/easy-fields-bundle": "*",
        "agence-adeliom/easy-media-bundle": "*",
        "agence-adeliom/easy-menu-bundle": "*",
        "agence-adeliom/easy-page-bundle": "*",
        "agence-adeliom/easy-redirect-bundle": "*",
        "agence-adeliom/easy-seo-bundle": "*",
        "composer/package-versions-deprecated": "1.11.99.2",
        "doctrine/annotations": "^1.13.3",
        "doctrine/doctrine-bundle": "^2.7.0",
        "doctrine/doctrine-migrations-bundle": "^3.1",
        "doctrine/orm": "^2.13",
        "easycorp/easyadmin-bundle": "^4.0",
        "friendsofsymfony/ckeditor-bundle": "^2.3",
        "phpdocumentor/reflection-docblock": "^5.2 || ^6.0",
        "sensio/framework-extra-bundle": "^6.1",
        "symfony/apache-pack": "^1.0",
        "symfony/asset": "6.0.*",
        "symfony/console": "6.0.*",
        "symfony/dotenv": "6.0.*",
        "symfony/expression-language": "6.0.*",
        "symfony/flex": "^1.9.0",
        "symfony/form": "6.0.*",
        "symfony/framework-bundle": "6.0.*",
        "symfony/http-client": "6.0.*",
        "symfony/intl": "6.0.*",
        "symfony/mailer": "6.0.*",
        "symfony/mime": "6.0.*",
        "symfony/monolog-bundle": "^3.1",
        "symfony/notifier": "6.0.*",
        "symfony/process": "6.0.*",
        "symfony/property-access": "6.0.*",
        "symfony/property-info": "6.0.*",
        "symfony/proxy-manager-bridge": "6.0.*",
        "symfony/runtime": "6.0.*",
        "symfony/security-bundle": "6.0.*",
        "symfony/serializer": "6.0.*",
        "symfony/string": "6.0.*",
        "symfony/translation": "6.0.*",
        "symfony/twig-bundle": "6.0.*",
        "symfony/validator": "6.0.*",
        "symfony/web-link": "6.0.*",
        "symfony/yaml": "6.0.*",
        "twig/twig": "^2.12|^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.10",
        "phpunit/phpunit": "^9.5",
        "rector/rector": "^0.14.0",
        "symfony/browser-kit": "6.0.*",
        "symfony/css-selector": "6.0.*",
        "symfony/debug-bundle": "6.0.*",
        "symfony/maker-bundle": "^1.0",
        "symfony/phpunit-bridge": "6.0.*",
        "symfony/stopwatch": "6.0.*",
        "symfony/var-dumper": "6.0.*",
        "symfony/web-profiler-bundle": "6.0.*"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "symfony/thanks": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "ckeditor:install --clear=drop": "symfony-cmd",
            "assets:install --symlink --relative %PUBLIC_DIR%": "symfony-cmd"
        },
        "links": [
            "rm -rf vendor/agence-adeliom/easy-admin-user-bundle",
            "rm -rf vendor/agence-adeliom/easy-block-bundle",
            "rm -rf vendor/agence-adeliom/easy-blog-bundle",
            "rm -rf vendor/agence-adeliom/easy-common-bundle",
            "rm -rf vendor/agence-adeliom/easy-config-bundle",
            "rm -rf vendor/agence-adeliom/easy-editor-bundle",
            "rm -rf vendor/agence-adeliom/easy-faq-bundle",
            "rm -rf vendor/agence-adeliom/easy-fields-bundle",
            "rm -rf vendor/agence-adeliom/easy-media-bundle",
            "rm -rf vendor/agence-adeliom/easy-menu-bundle",
            "rm -rf vendor/agence-adeliom/easy-page-bundle",
            "rm -rf vendor/agence-adeliom/easy-redirect-bundle",
            "rm -rf vendor/agence-adeliom/easy-seo-bundle",
            "ln -s ../../lib/EasyAdminUserBundle vendor/agence-adeliom/easy-admin-user-bundle",
            "ln -s ../../lib/EasyConfigBundle vendor/agence-adeliom/easy-config-bundle",
            "ln -s ../../lib/EasyBlockBundle vendor/agence-adeliom/easy-block-bundle",
            "ln -s ../../lib/EasyBlogBundle vendor/agence-adeliom/easy-blog-bundle",
            "ln -s ../../lib/EasyCommonBundle vendor/agence-adeliom/easy-common-bundle",
            "ln -s ../../lib/EasyEditorBundle vendor/agence-adeliom/easy-editor-bundle",
            "ln -s ../../lib/EasyFaqBundle vendor/agence-adeliom/easy-faq-bundle",
            "ln -s ../../lib/EasyFieldsBundle vendor/agence-adeliom/easy-fields-bundle",
            "ln -s ../../lib/EasyMediaBundle vendor/agence-adeliom/easy-media-bundle",
            "ln -s ../../lib/EasyMenuBundle vendor/agence-adeliom/easy-menu-bundle",
            "ln -s ../../lib/EasyPageBundle vendor/agence-adeliom/easy-page-bundle",
            "ln -s ../../lib/EasyRedirectBundle vendor/agence-adeliom/easy-redirect-bundle",
            "ln -s ../../lib/EasySeoBundle vendor/agence-adeliom/easy-seo-bundle"
        ],
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "extra": {
        "symfony": {
            "endpoint": [
                "flex://defaults"
            ],
            "allow-contrib": false,
            "require": "6.0.*"
        }
    }
}
