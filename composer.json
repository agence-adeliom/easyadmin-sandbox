{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "lib/EasyMediaBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyEditorBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyFieldsBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyCommonBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyPageBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyBlogBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasySeoBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyBlockBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyShopBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyFaqBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyMenuBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyAdminUserBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyConfigBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "lib/EasyRedirectBundle",
            "canonical": false,
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "ext-ctype": "*",
        "ext-exif": "*",
        "ext-iconv": "*",
        "ext-json": "*",
        "agence-adeliom/easy-admin-user-bundle": "^1.0",
        "agence-adeliom/easy-block-bundle": "^1.0",
        "agence-adeliom/easy-blog-bundle": "^1.0",
        "agence-adeliom/easy-common-bundle": "^1.0",
        "agence-adeliom/easy-config-bundle": "^1.0",
        "agence-adeliom/easy-editor-bundle": "^1.0",
        "agence-adeliom/easy-faq-bundle": "^1.0",
        "agence-adeliom/easy-fields-bundle": "^1.0",
        "agence-adeliom/easy-media-bundle": "^1.0",
        "agence-adeliom/easy-menu-bundle": "^1.0",
        "agence-adeliom/easy-page-bundle": "^1.0",
        "agence-adeliom/easy-redirect-bundle": "^1.0",
        "agence-adeliom/easy-seo-bundle": "^1.0",
        "agence-adeliom/easy-shop-bundle": "^1.0",
        "composer/package-versions-deprecated": "1.11.99.2",
        "doctrine/annotations": "^1.0",
        "doctrine/doctrine-bundle": "^2.4",
        "doctrine/doctrine-migrations-bundle": "^3.1",
        "doctrine/orm": "^2.9",
        "easycorp/easyadmin-bundle": "^3.4",
        "flux-se/sylius-payum-monetico-plugin": "^1.1",
        "friendsofsymfony/ckeditor-bundle": "^2.3",
        "phpdocumentor/reflection-docblock": "^5.2",
        "sensio/framework-extra-bundle": "^6.1",
        "symfony/apache-pack": "^1.0",
        "symfony/asset": "6.0.3",
        "symfony/console": "6.0.5",
        "symfony/dotenv": "6.0.5",
        "symfony/expression-language": "6.0.3",
        "symfony/flex": "2.1.6",
        "symfony/form": "6.0.5",
        "symfony/framework-bundle": "6.0.6",
        "symfony/http-client": "6.0.5",
        "symfony/intl": "6.0.5",
        "symfony/mailer": "6.0.5",
        "symfony/mime": "6.0.3",
        "symfony/monolog-bundle": "^3.1",
        "symfony/notifier": "6.0.6",
        "symfony/process": "6.0.5",
        "symfony/property-access": "6.0.5",
        "symfony/property-info": "6.0.3",
        "symfony/proxy-manager-bridge": "6.0.6",
        "symfony/runtime": "6.0.5",
        "symfony/security-bundle": "6.0.5",
        "symfony/serializer": "6.0.6",
        "symfony/string": "6.0.3",
        "symfony/translation": "6.0.6",
        "symfony/twig-bundle": "6.0.3",
        "symfony/validator": "6.0.6",
        "symfony/web-link": "6.0.3",
        "symfony/yaml": "6.0.3",
        "twig/twig": "^2.12|^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "symfony/browser-kit": "6.0.3",
        "symfony/css-selector": "6.0.3",
        "symfony/debug-bundle": "6.0.3",
        "symfony/maker-bundle": "^1.0",
        "symfony/phpunit-bridge": "6.0.3",
        "symfony/stopwatch": "6.0.5",
        "symfony/var-dumper": "6.0.6",
        "symfony/web-profiler-bundle": "6.0.6"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "ckeditor:install --clear=drop": "symfony-cmd",
            "assets:install --symlink --relative %PUBLIC_DIR%": "symfony-cmd"
        },
        "links": [
            "ln -s lib/EasyShopBundle vendor/agence-adeliom/easy-shop-bundle"
        ],
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "endpoint": "https://recipes.adev2.com/",
            "allow-contrib": false,
            "require": "^5.2"
        }
    }
}
