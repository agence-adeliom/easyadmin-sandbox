{
    "name": "agence-adeliom/easy-redirect-bundle",
    "type": "symfony-bundle",
    "description": "Symfony redirection bundle for EasyAdmin",
    "keywords": [
        "symfony",
        "redirection",
        "easyadmin"
    ],
    "homepage": "https://github.com/agence-adeliom/easy-redirect-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Arnaud RITTI",
            "homepage": "https://github.com/arnaud-ritti"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "easycorp/easyadmin-bundle": "^3.4 || ^v4.0",
        "agence-adeliom/easy-common-bundle": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Adeliom\\EasyRedirectBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Adeliom\\EasyRedirectBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:agence-adeliom/easy-common-bundle.git"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "11.5.x-dev"
    }
}
