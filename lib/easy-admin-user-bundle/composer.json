{
    "name": "agence-adeliom/easy-admin-user-bundle",
    "type": "symfony-bundle",
    "description": "A Symfony bundle for EasyAdmin that provide basic user authentification flow",
    "keywords": [
        "symfony",
        "easyadmin",
        "user"
    ],
    "homepage": "https://github.com/agence-adeliom/easy-admin-user-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Arnaud RITTI",
            "homepage": "https://github.com/arnaud-ritti"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/form": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "symfony/mailer": "^6.4 || ^7.0",
        "symfony/mime": "^6.4 || ^7.0",
        "symfony/options-resolver": "^6.4 || ^7.0",
        "symfony/password-hasher": "^6.4 || ^7.0",
        "symfony/validator": "^6.4 || ^7.0",
        "symfony/stopwatch": "^6.4 || ^7.0",
        "easycorp/easyadmin-bundle": "^3.4 || ^v4.0",
        "agence-adeliom/easy-common-bundle": "^3.x-dev",
        "symfonycasts/reset-password-bundle": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Adeliom\\EasyAdminUserBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Adeliom\\EasyAdminUserBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:agence-adeliom/easy-common-bundle"
        }
    ]
}
