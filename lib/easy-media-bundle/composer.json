{
    "name": "agence-adeliom/easy-media-bundle",
    "type": "symfony-bundle",
    "description": "A Symfony Media manager bundle for EasyAdmin",
    "keywords": [
        "symfony",
        "easyadmin",
        "media",
        "media-manager"
    ],
    "homepage": "https://github.com/agence-adeliom/easy-media-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Arnaud RITTI",
            "homepage": "https://github.com/arnaud-ritti"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/deprecation-contracts": "^2.2 || ^v3.0",
        "symfony/event-dispatcher": "^6.4 || ^7.0",
        "symfony/form": "^6.4 || ^7.0",
        "symfony/framework-bundle": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "symfony/options-resolver": "^6.4 || ^7.0",
        "symfony/property-access": "^6.4 || ^7.0",
        "symfony/filesystem": "^6.4 || ^7.0",
        "easycorp/easyadmin-bundle": "^3.4 || ^v4.0",
        "agence-adeliom/easy-common-bundle": "^3.0",
        "league/flysystem-bundle": "^3.0",
        "liip/imagine-bundle": "^2.13",
        "maennchen/zipstream-php": "^2.1.0",
        "illuminate/support": "^12.0",
        "stof/doctrine-extensions-bundle": "^1.13",
        "symfony/psr-http-message-bridge": "^7.2",
        "nyholm/psr7": "^1.8",
        "embed/embed": "^4.4",
        "james-heinrich/getid3": "^1.9"
    },
    "autoload": {
        "psr-4": {
            "Adeliom\\EasyMediaBundle\\": "src/"
        }
    },
    "minimum-stability": "alpha",
    "repositories": [
        {
            "type": "path",
            "url": "../easy-common-bundle",
            "options": {
                "symlink": true
            }
        }
    ]
}
