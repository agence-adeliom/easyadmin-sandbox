{
    "name": "agence-adeliom/easy-seo-bundle",
    "type": "symfony-bundle",
    "description": "Symfony SEO bundle for EasyAdmin",
    "keywords": [
        "symfony",
        "SEO",
        "sitemap",
        "breadcrumb",
        "metadata",
        "easyadmin"
    ],
    "homepage": "https://github.com/agence-adeliom/easy-seo-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Arnaud RITTI",
            "homepage": "https://github.com/arnaud-ritti"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/deprecation-contracts": "^2.2 || ^v3.0",
        "symfony/event-dispatcher": "^6.4 || ^7.0",
        "symfony/framework-bundle": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "symfony/options-resolver": "^6.4 || ^7.0",
        "symfony/property-access": "^6.4 || ^7.0",
        "easycorp/easyadmin-bundle": "^3.4 || ^v4.0",
        "agence-adeliom/easy-common-bundle": "^3.0",
        "agence-adeliom/easy-media-bundle": "^3.0",
        "presta/sitemap-bundle": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Adeliom\\EasySeoBundle\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "repositories": [
        {
            "type": "path",
            "url": "../easy-common-bundle",
            "options": {
                "symlink": true
            }
        }
    ]
}
