{
    "name": "agence-adeliom/easy-common-bundle",
    "type": "symfony-bundle",
    "description": "A Symfony bundle for EasyAdmin that provide basic entity traits and a enum helper",
    "keywords": [
        "symfony",
        "easyadmin",
        "enum",
        "helper"
    ],
    "homepage": "https://github.com/agence-adeliom/easy-common-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Arnaud RITTI",
            "homepage": "https://github.com/arnaud-ritti"
        },
        {
            "name": "Jean-David Daviet",
            "homepage": "https://github.com/JeanDavidDaviet"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "symfony/serializer": "^6.4 || ^7.0",
        "easycorp/easyadmin-bundle": "^3.4 || ^v4.0",
        "gedmo/doctrine-extensions": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Adeliom\\EasyCommonBundle\\": "src/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "symfony/yaml": "^6.4 || ^7.0"
    }
}
