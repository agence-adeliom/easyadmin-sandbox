{
    "name": "agence-adeliom/easy-page-bundle",
    "type": "symfony-bundle",
    "description": "A simple lightweight CMS bundle for Symfony",
    "keywords": [
        "symfony",
        "cms",
        "easyadmin"
    ],
    "homepage": "https://github.com/agence-adeliom/easy-page-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Arnaud RITTI",
            "homepage": "https://github.com/arnaud-ritti"
        },
        {
            "name": "Jean-David Daviet",
            "homepage": "https://github.com/JeanDavidDaviet"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/deprecation-contracts": "^2.2 || ^v3.0",
        "symfony/event-dispatcher": "^6.4 || ^7.0",
        "symfony/form": "^6.4 || ^7.0",
        "symfony/framework-bundle": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "symfony/options-resolver": "^6.4 || ^7.0",
        "symfony/property-access": "^6.4 || ^7.0",
        "symfony/webpack-encore-bundle": "^2.2.0",
        "easycorp/easyadmin-bundle": "^3.4 || ^v4.0",
        "agence-adeliom/easy-common-bundle": "^3.0.1",
        "agence-adeliom/easy-seo-bundle": "^3.0.1",
        "agence-adeliom/easy-fields-bundle": "^3.0.1",
        "stof/doctrine-extensions-bundle": "^1.13"
    },
    "autoload": {
        "psr-4": {
            "Adeliom\\EasyPageBundle\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:agence-adeliom/easy-common-bundle"
        },
        {
            "type": "vcs",
            "url": "git@github.com:agence-adeliom/easy-seo-bundle"
        },
        {
            "type": "vcs",
            "url": "git@github.com:agence-adeliom/easy-fields-bundle"
        }
    ]
}
