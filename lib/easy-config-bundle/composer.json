{
    "name": "agence-adeliom/easy-config-bundle",
    "type": "symfony-bundle",
    "description": "A Symfony bundle for EasyAdmin that provide a configuration system",
    "keywords": [
        "symfony",
        "easyadmin",
        "config"
    ],
    "homepage": "https://github.com/agence-adeliom/easy-config-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Arnaud RITTI",
            "homepage": "https://github.com/arnaud-ritti"
        },
        {
            "name": "Jean-David Daviet",
            "homepage": "https://github.com/JeanDavidDaviet"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/deprecation-contracts": "^2.2 || ^v3.0",
        "symfony/event-dispatcher": "^6.4 || ^7.0",
        "symfony/form": "^6.4 || ^7.0",
        "symfony/framework-bundle": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "symfony/options-resolver": "^6.4 || ^7.0",
        "symfony/property-access": "^6.4 || ^7.0",
        "easycorp/easyadmin-bundle": "^4.10",
        "agence-adeliom/easy-common-bundle": "^3.1",
        "agence-adeliom/easy-fields-bundle": "^3.1",
        "agence-adeliom/easy-media-bundle": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "Adeliom\\EasyConfigBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Adeliom\\EasyConfigBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:agence-adeliom/easy-common-bundle"
        },
        {
            "type": "vcs",
            "url": "git@github.com:agence-adeliom/easy-fields-bundle"
        },
        {
            "type": "vcs",
            "url": "git@github.com:agence-adeliom/easy-media-bundle"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    }
}
