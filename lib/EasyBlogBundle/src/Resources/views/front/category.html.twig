{% extends '@EasyBlog/front/index.html.twig' %}

{% block title %}{{- seo_title(category.name) -}}{% endblock %}

{% block easy_page_head_metas %}{{- seo_metas(category.seo) -}}{% endblock %}

{% block easy_page_page_content %}
    <section>
        <article>
            <h1>{{ category.name }}</h1>

            <h2>Posts</h2>
            <ul>
                {% for post in posts %}
                    <li>
                        <a href="{{ path('easy_blog_post_index', {"category" : post.category.slug, "post" : post.slug}) }}">{{ post.name }}</a>
                    </li>
                {% endfor %}
            </ul>
        </article>
    </section>
{% endblock %}
