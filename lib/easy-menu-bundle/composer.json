{
    "name": "agence-adeliom/easy-menu-bundle",
    "type": "symfony-bundle",
    "description": "A Symfony Menu bundle for EasyAdmin",
    "keywords": [
        "symfony",
        "easyadmin",
        "menu",
        "menu-manager"
    ],
    "homepage": "https://github.com/agence-adeliom/easy-menu-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Jerome ENGELN",
            "homepage": "https://github.com/JeromeEngelnAdeliom"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/deprecation-contracts": "^2.2 || ^v3.0",
        "symfony/event-dispatcher": "^6.4 || ^7.0",
        "symfony/form": "^6.4 || ^7.0",
        "symfony/framework-bundle": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "symfony/options-resolver": "^6.4 || ^7.0",
        "symfony/property-access": "^6.4 || ^7.0",
        "easycorp/easyadmin-bundle": "^3.4 || ^v4.0",
        "agence-adeliom/easy-common-bundle": "^3.x-dev",
        "agence-adeliom/easy-fields-bundle": "^3.x-dev",
        "stof/doctrine-extensions-bundle": "^1.13"
    },
    "autoload": {
        "psr-4": {
            "Adeliom\\EasyMenuBundle\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:agence-adeliom/easy-common-bundle"
        },
        {
            "type": "vcs",
            "url": "git@github.com:agence-adeliom/easy-fields-bundle"
        }
    ]
}
