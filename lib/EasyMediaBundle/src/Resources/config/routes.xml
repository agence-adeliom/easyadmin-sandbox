<?xml version="1.0" encoding="UTF-8" ?>
<routes xmlns="http://symfony.com/schema/routing"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://symfony.com/schema/routing
        http://symfony.com/schema/routing/routing-1.0.xsd">

    <route methods="GET" id="media.index" controller="Adeliom\EasyMediaBundle\Controller\MediaController::index" path="/" ></route>
    <route methods="GET" id="media.browse" controller="Adeliom\EasyMediaBundle\Controller\MediaController::browse" path="/browse" ></route>

    <route methods="POST" id="media.upload" controller="Adeliom\EasyMediaBundle\Controller\MediaController::upload" path="/upload" ></route>
    <route methods="POST" id="media.uploadCropped" controller="Adeliom\EasyMediaBundle\Controller\MediaController::uploadEditedImage" path="/upload-cropped" ></route>
    <route methods="POST" id="media.uploadLink" controller="Adeliom\EasyMediaBundle\Controller\MediaController::uploadLink" path="/upload-link" ></route>

    <route methods="POST" id="media.get_files" controller="Adeliom\EasyMediaBundle\Controller\MediaController::getFiles" path="/get-files" ></route>
    <route methods="POST" id="media.get_file_info" controller="Adeliom\EasyMediaBundle\Controller\MediaController::getItemInfos" path="/get-file-info" ></route>
    <route methods="POST" id="media.new_folder" controller="Adeliom\EasyMediaBundle\Controller\MediaController::createNewFolder" path="/create-new-folder" ></route>
    <route methods="POST" id="media.delete_file" controller="Adeliom\EasyMediaBundle\Controller\MediaController::deleteItem" path="/delete-file" ></route>
    <route methods="POST" id="media.move_file" controller="Adeliom\EasyMediaBundle\Controller\MediaController::moveItem" path="/move-file" ></route>
    <route methods="POST" id="media.rename_file" controller="Adeliom\EasyMediaBundle\Controller\MediaController::renameItem" path="/rename-file" ></route>
    <route methods="POST" id="media.edit_metas_file" controller="Adeliom\EasyMediaBundle\Controller\MediaController::editMetasItem" path="/edit-metas-file" ></route>
    <route methods="POST" id="media.change_vis" controller="Adeliom\EasyMediaBundle\Controller\MediaController::changeItemVisibility" path="/change-visibility" ></route>
    <route methods="POST" id="media.lock_file" controller="Adeliom\EasyMediaBundle\Controller\MediaController::lockItem" path="/lock-file" ></route>

    <route methods="GET" id="media.global_search" controller="Adeliom\EasyMediaBundle\Controller\MediaController::globalSearch" path="/global-search" ></route>
    <route methods="POST" id="media.locked_list" controller="Adeliom\EasyMediaBundle\Controller\MediaController::getLockList" path="/get-locked-list" ></route>

    <route methods="POST" id="media.folder_download" controller="Adeliom\EasyMediaBundle\Controller\MediaController::downloadFolder" path="/folder-download" ></route>
    <route methods="POST" id="media.files_download" controller="Adeliom\EasyMediaBundle\Controller\MediaController::downloadFiles" path="/files-download" ></route>

</routes>
