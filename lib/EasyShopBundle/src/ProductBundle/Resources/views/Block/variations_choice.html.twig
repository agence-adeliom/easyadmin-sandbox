{% block product_variation_javascript_init %}
    {% if form is not same as(null) %}
        {% set variationIds = [] %}
        {% for formItem in form.children %}
            {% set variationIds = variationIds|merge(["$('#" ~ formItem.vars.id ~ "')"]) %}
        {% endfor %}

        <script type="text/javascript">
            jQuery(document).ready(function() {
                EasyShop.Product.setOptions({
                    variations: {
                        fields: [{{ variationIds|join(', ')|raw }}],
                        form: $('#easy_shop_variation_form'),
                        unavailableError: $('#easy_shop_variation_error')
                    }});
                EasyShop.Product.initVariation();
            });
        </script>
    {% endif %}
{% endblock %}


{% block product_variation_form %}
    <div class="alert alert-danger" id="easy_shop_variation_error"{% if settings.product is not same as(null) %} style="display:none;"{% endif %}>{% if settings.product is  same as(null) %}{% trans from "SonataProductBundle" %}no_product_found{% endtrans %}{% endif %}</div>

    {% if settings.product is not same as(null) %}
        <form action="{{ url(settings.form_route, settings.form_route_parameters) }}" id="easy_shop_variation_form" class="form-horizontal" role="form">
            {{ form_widget(form) }}
        </form>
    {% endif %}
{% endblock %}
