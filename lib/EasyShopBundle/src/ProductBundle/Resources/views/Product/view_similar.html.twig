{% spaceless %}

    <div class="panel panel-primary">

        <div class="panel-heading">
            <h3 class="panel-title">{% trans from "SonataProductBundle" %}easy_shop.product.cross_selling.title{% endtrans %}</h3>
        </div>

        <div class="panel-body product-grid">
            <div class="col-lg-12">
                {% easy_shop_template_box 'This is the similar product view template. Feel free to override it.' %}
            </div>

            <div class="col-lg-12">
                {{ easy_shop_block_render({'type': 'easy_shop.product.block.similar_products', 'settings': {'title': '', 'number': 4, 'base_product_id': product.id}}) }}
            </div>
        </div>

    </div>

{% endspaceless %}
