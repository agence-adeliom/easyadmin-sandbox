<h2>{% trans from 'SonataProductBundle' %}title_list_variations{% endtrans %}</h2>

{% if product.variations.count == 0 %}
    {% trans from 'SonataProductBundle' %}no_variations_available{% endtrans %}
{% else %}
    <ul>
        {% for variation in product.enabledVariations %}
            <li><a href="{{ url('easy_shop_product_view', {'productId': variation.id, 'slug': variation.slug}) }}">{{ variation.name }}</a></li>
        {% endfor %}
    </ul>
{% endif %}
