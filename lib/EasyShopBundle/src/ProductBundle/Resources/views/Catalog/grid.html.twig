<div class="panel-body product-grid">

    {% easy_shop_template_box 'This is the product grid list template. Feel free to override it.' %}

    {% for product in pager %}

        {% if not easy_shop_product_has_variations(product) or (easy_shop_product_has_variations(product) and easy_shop_product_has_enabled_variations(product)) %}

            <div class="col-sm-4" itemscope itemtype="http://schema.org/Product">
                {% include '@SonataProduct/Catalog/_product_grid.html.twig' %}
            </div>

        {% endif %}

    {% endfor %}

</div>
