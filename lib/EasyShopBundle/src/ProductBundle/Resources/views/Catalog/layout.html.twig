{% easy_shop_template_box 'This is the catalog template. Feel free to override it.' %}

{% block easy_shop_page_breadcrumb %}
    <div class="row-fluid clearfix">
        {% if category is defined %}
            {{ easy_shop_block_render_event('breadcrumb', { 'context': 'catalog', 'category': category, 'current_uri': app.request.requestUri }) }}
        {% elseif collection is defined %}
            {{ easy_shop_block_render_event('breadcrumb', { 'context': 'catalog', 'collection': collection, 'current_uri': app.request.requestUri }) }}
        {% endif %}
    </div>
{% endblock %}

<div class="row">

    <div class="col-sm-3">

        {% block product_category %}
            {{ easy_shop_block_render({'type': 'easy_shop.product.block.categories_menu', 'settings': {
                'current_uri': app.request.requestUri,
                'extra_cache_keys': {
                    'block_id':    'easy_shop.product.block.categories_menu',
                    'updated_at':  'now',
                },
                'ttl': 60
            }}) }}
        {% endblock %}

        {#{% block product_filter %}#}
            {#{% if provider %}#}
                {#<div class="well" style="padding: 8px 0;">#}
                    {#{{ easy_shop_block_render({'type': 'easy_shop.product.block.filters_menu'}, {'product_provider': provider, 'current_uri': app.request.requestUri}) }}#}
                {#</div>#}
            {#{% endif %}#}
        {#{% endblock %}#}

    </div>

    <div class="col-sm-9">

        {% if pager.count == 0 %}

            {% block no_products %}
                <div class="no-products-available">
                    {% trans from 'SonataProductBundle' %}no_products_available{% endtrans %}
                </div>
            {% endblock %}

        {% else %}

            <div class="panel panel-default sonata-product-navigation-bar">
                <div class="panel-heading">
                    <div class="row">
                        <div class="col-sm-3">
                            <h4 class="panel-title">
                                {% block products_heading_title %}{%endblock%}
                            </h4>
                        </div>
                        <div class="col-sm-9">
                            {% include '@SonataProduct/Catalog/_pager.html.twig' %}
                        </div>
                    </div>
                </div>

                {% block products %}{% endblock %}

                {% if pager.paginationData.pageCount > 1 %}
                    <div class="panel-footer">
                        <div class="row">
                            <div class="col-sm-12">
                                {% include '@SonataProduct/Catalog/_pager.html.twig' %}
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>
        {% endif %}

    </div>

</div>
