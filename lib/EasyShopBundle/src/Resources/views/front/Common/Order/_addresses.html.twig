<div class="row mt-4 mb-4">
    <div class="col-12 col-sm-6" id="sylius-billing-address" {{ sylius_test_html_attribute('billing-address') }}>
        <h6>{{ 'sylius.ui.billing_address'|trans }}</h6>
        {% include '@EasyShop/front/Common/_address.html.twig' with {'address': order.billingAddress} %}
    </div>
    <div class="col-12 col-sm-6" id="sylius-shipping-address" {{ sylius_test_html_attribute('shipping-address') }}>
        <h6>{{ 'sylius.ui.shipping_address'|trans }}</h6>
        {% include '@EasyShop/front/Common/_address.html.twig' with {'address': order.shippingAddress} %}
    </div>
</div>
