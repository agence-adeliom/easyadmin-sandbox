{% import "@EasyShop/front/Common/Macro/money.html.twig" as money %}

{% set state = order.paymentState %}

{% if state != 'cart' %}
    {% include "@EasyShop/front/Common/Order/Label/PaymentState/orderPaymentState.html.twig" %}
{% endif %}

{% for payment in order.payments %}
    {% set state = payment.state %}
    <div class="card">
        <div class="card-body">
            <h6 class="card-title" id="sylius-payment-method" {{ sylius_test_html_attribute('payment-method') }}>
                {{ payment.method }}
            </h6>
            <p class="mb-0 mt-2" {{ sylius_test_html_attribute('payment-price') }}>{{ money.format(payment.amount, payment.currencyCode) }}</p>
            {% if state != 'cart' %}
            <p id="payment-status" class="mb-0 mt-3" {{ sylius_test_html_attribute('payment-state') }}>
                {% include "@EasyShop/front/Common/Order/Label/PaymentState/singlePaymentState.html.twig" with { 'state': state } %}
            </p>
            {% endif %}
        </div>
    </div>
{% endfor %}
