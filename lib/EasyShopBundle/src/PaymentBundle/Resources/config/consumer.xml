<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <parameters>
        <parameter key="easy_shop.payment.consumer.order_process.class">Adeliom\EasyShop\PaymentBundle\Consumer\PaymentProcessOrderConsumer</parameter>
        <parameter key="easy_shop.payment.consumer.order_element_process.class">Adeliom\EasyShop\PaymentBundle\Consumer\PaymentProcessOrderElementConsumer</parameter>
    </parameters>
    <services>
        <service id="easy_shop.payment.consumer.order_process" class="%easy_shop.payment.consumer.order_process.class%">
            <tag name="easy_shop.notification.consumer" type="easy_shop_payment_order_process"/>
            <argument type="service" id="easy_shop.order.manager"/>
            <argument type="service" id="easy_shop.transaction.manager"/>
            <argument type="service" id="easy_shop.notification.backend"/>
        </service>
        <service id="easy_shop.payment.consumer.order_element_process" class="%easy_shop.payment.consumer.order_element_process.class%">
            <tag name="easy_shop.notification.consumer" type="easy_shop_payment_order_element_process"/>
            <argument type="service" id="easy_shop.order.order_element.manager"/>
            <argument type="service" id="easy_shop.product.pool"/>
        </service>
    </services>
</container>
