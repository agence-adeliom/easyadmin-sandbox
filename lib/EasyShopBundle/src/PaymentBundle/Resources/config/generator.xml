<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <parameters>
        <parameter key="easy_shop.payment.generator.mysql.class">Adeliom\EasyShop\Component\Generator\MysqlReference</parameter>
        <parameter key="easy_shop.payment.generator.postgres.class">Adeliom\EasyShop\Component\Generator\PostgresReference</parameter>
    </parameters>
    <services>
        <service id="easy_shop.payment.generator.mysql" class="%easy_shop.payment.generator.mysql.class%">
            <argument type="service" id="doctrine"/>
        </service>
        <service id="easy_shop.payment.generator.postgres" class="%easy_shop.payment.generator.postgres.class%">
            <argument type="service" id="doctrine"/>
        </service>
    </services>
</container>
