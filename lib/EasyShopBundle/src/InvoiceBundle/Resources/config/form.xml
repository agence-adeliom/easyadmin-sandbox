<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="easy_shop.invoice.form.status_type" class="Adeliom\EasyShop\InvoiceBundle\Form\Type\InvoiceStatusType">
            <argument>%easy_shop.invoice.invoice.class%</argument>
            <argument>getStatusList</argument>
            <argument>easy_shop_invoice_status</argument>
            <tag name="form.type" alias="easy_shop_invoice_status"/>
        </service>
    </services>
</container>
