<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="easy_shop.order.serializer.handler.order" class="Adeliom\EasyShop\OrderBundle\Serializer\OrderSerializerHandler">
            <tag name="jms_serializer.subscribing_handler"/>
            <argument type="service" id="easy_shop.order.manager"/>
        </service>
        <service id="easy_shop.order.serializer.handler.order_element" class="Adeliom\EasyShop\OrderBundle\Serializer\OrderElementSerializerHandler">
            <tag name="jms_serializer.subscribing_handler"/>
            <argument type="service" id="easy_shop.order.order_element.manager"/>
        </service>
    </services>
</container>
