{% extends easy_shop_customer.profileTemplate %}

{% block easy_shop_profile_title %}{% trans from 'SonataCustomerBundle' %}address_new{% endtrans %}{% endblock %}

{% block easy_shop_profile_content %}

{% easy_shop_template_box 'This is the customer address creation template. Feel free to override it.' %}

{{ form_start(form, {'attr': {'class': 'form-horizontal'}}) }}
    {{ form_errors(form) }}
    {{ form_rest(form) }}
    <div class="form-actions">
        <button type="submit" class="btn btn-success pull-right">{{ 'easy_shop.customer.address.save'|trans({}, 'SonataCustomerBundle') }}</button>
    </div>
{{ form_end(form) }}

{% endblock %}
