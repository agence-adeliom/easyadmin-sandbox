{% extends easy_shop_block.templates.block_base %}

{% block block %}

    <div class="box box-primary">
        {% if settings.title %}
            <div class="box-header with-border">
                <h3 class="box-title">
                    <i class="fa fa-user"></i> {{ settings.title }}
                </h3>
            </div>
        {% endif %}

        <div class="box-body">
            {% if customers|length > 0 %}
                <div class="easy_shop-customer-block-customer-container list-group">
                    {% for customer in customers %}
                        <a class="list-group-item"
                           href="
                            {% if context.getSetting('mode') == 'admin' and admin_pool is defined %}
                                {{ admin_pool.getAdminByAdminCode('easy_shop.customer.admin.customer').generateUrl('edit', { 'id': customer.id }) }}
                            {% else %}
                                {{ url('easy_shop_customer_view', { 'id': customer.id }) }}
                            {% endif %}
                            ">
                            {{ customer }} - {{ customer.createdAt|format_datetime() }}
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <p>{{ 'no_customer_found'|trans({}, 'SonataCustomerBundle') }}</p>
            {% endif %}
        </div>

        <div class="box-footer">
            {% if context.getSetting('mode') == 'admin' and admin_pool is defined  %}
                <a href="{{ admin_pool.getAdminByAdminCode('easy_shop.customer.admin.customer').generateUrl('list') }}" class="btn btn-primary btn-block"><i class="fa fa-list"></i>&nbsp;{{ 'view_all_customers'|trans({}, 'SonataCustomerBundle') }}</a>
            {% endif %}
        </div>
    </div>

{% endblock %}
