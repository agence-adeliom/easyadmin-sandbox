<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="easy_shop.customer.api.form.type.customer" class="Adeliom\EasyShop\CustomerBundle\Form\Type\ApiCustomerType">
            <tag name="form.type" alias="easy_shop_customer_api_form_customer"/>
            <argument type="service" id="jms_serializer.metadata_factory"/>
            <argument type="service" id="doctrine"/>
            <argument>easy_shop_customer_api_form_customer</argument>
            <argument>%easy_shop.customer.admin.customer.entity%</argument>
            <argument>easy_shop_api_write</argument>
        </service>
        <service id="easy_shop.customer.api.form.type.address" class="Adeliom\EasyShop\CustomerBundle\Form\Type\ApiAddressType">
            <tag name="form.type" alias="easy_shop_customer_api_form_address"/>
            <argument type="service" id="jms_serializer.metadata_factory"/>
            <argument type="service" id="doctrine"/>
            <argument>easy_shop_customer_api_form_address</argument>
            <argument>%easy_shop.customer.admin.address.entity%</argument>
            <argument>easy_shop_api_write</argument>
        </service>
    </services>
</container>
